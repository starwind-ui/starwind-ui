{
  "name": "starwind",
  "version": "3.0.0-beta.3",
  "description": "Install and manage Starwind UI components in Astro and React applications",
  "license": "MIT",
  "homepage": "https://starwind.dev/",
  "author": {
    "name": "boston343",
    "url": "https://x.com/boston343builds"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/starwind-ui/starwind-ui.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "starwind",
    "starwind-ui",
    "starwind-cli",
    "astro",
    "astro-component",
    "astro-ui",
    "react",
    "react-component",
    "withastro",
    "ui",
    "accessibility",
    "tailwind",
    "components"
  ],
  "type": "module",
  "bin": {
    "starwind": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "cli:link": "pnpm add --global . --ignore-scripts",
    "cli:unlink": "pnpm rm --global starwind",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --ignore-path ../../.prettierignore --check \"**/*.{ts,tsx,md,json}\"",
    "format:write": "prettier --ignore-path ../../.prettierignore --write \"**/*.{ts,tsx,md,json}\" --cache",
    "publish:beta": "pnpm publish --tag beta --access public",
    "publish:next": "pnpm publish --tag next --access public",
    "publish:release": "pnpm publish --access public"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.2",
    "jsonc-parser": "^3.3.1",
    "semver": "^7.7.3",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.10.1",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
