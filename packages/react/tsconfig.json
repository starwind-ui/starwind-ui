{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@starwind-ui/runtime": ["../runtime/src/index.ts"],
      "@starwind-ui/runtime/init-starwind": ["../runtime/src/init-starwind.ts"],
      "@starwind-ui/runtime/theme": ["../runtime/src/theme/theme.ts"],
      "@starwind-ui/runtime/*": ["../runtime/src/components/*/index.ts"]
    },
    "types": ["node", "react", "react-dom"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tsup.config.ts"],
  "exclude": ["dist", "node_modules"]
}
