---
import { Image } from "astro:assets";
/**
 * Generated by scripts/portable-runtime/generate-astro-wrappers.ts.
 * Do not edit by hand; update the contract/template instead.
 */
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"img"> & {
  alt: string;
  image?: ImageMetadata;
  src?: string;
};

const { src, image, alt, width, height, style, ...rest } = Astro.props;
const initialStyle =
  typeof style === "string" ? `${style};visibility: hidden` : { ...style, visibility: "hidden" };

if (!src && !image) {
  throw new Error("Either 'src' or 'image' is required for an avatar image.");
}
---

{
  src && (
    <img
      data-sw-avatar-image
      data-image-loading-status="idle"
      src={src}
      alt={alt}
      width={64}
      height={64}
      style={initialStyle}
      {...rest}
    />
  )
}
{
  image && (
    <Image
      data-sw-avatar-image
      data-image-loading-status="idle"
      src={image}
      alt={alt}
      width={64}
      style={initialStyle}
      {...rest}
    />
  )
}
