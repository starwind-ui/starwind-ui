---
import { Image } from "astro:assets";
/**
 * Generated by scripts/portable-runtime/generate-astro-wrappers.ts.
 * Do not edit by hand; update the contract/template instead.
 */
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"img"> & {
  alt: string;
  image?: ImageMetadata;
  src?: string;
};

const { src, image, alt, width, height, ...rest } = Astro.props;

if (!src && !image) {
  throw new Error("Either 'src' or 'image' is required for an avatar image.");
}
---

{
  src && (
    <img
      data-sw-avatar-image
      data-image-loading-status="idle"
      hidden
      src={src}
      alt={alt}
      width={64}
      height={64}
      {...rest}
    />
  )
}
{
  image && (
    <Image
      data-sw-avatar-image
      data-image-loading-status="idle"
      hidden
      src={image}
      alt={alt}
      width={64}
      {...rest}
    />
  )
}
