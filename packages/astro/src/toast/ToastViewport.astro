---
/**
 * Generated by scripts/portable-runtime/generate-astro-wrappers.ts.
 * Do not edit by hand; update the contract/template instead.
 */
import type { HTMLAttributes } from "astro/types";

type Position =
  | "top-left"
  | "top-center"
  | "top-right"
  | "bottom-left"
  | "bottom-center"
  | "bottom-right";

type Props = HTMLAttributes<"div"> & {
  duration?: number;
  gap?: string;
  limit?: number;
  peek?: string;
  position?: Position;
};

const {
  duration = 5000,
  gap = "0.5rem",
  limit = 3,
  peek = "1rem",
  position = "bottom-right",
  style,
  ...rest
} = Astro.props;

const viewportStyle = [`--gap: ${gap}`, `--peek: ${peek}`, style].filter(Boolean).join("; ");
---

<div
  data-sw-toast-viewport
  data-position={position}
  data-limit={limit}
  data-duration={duration}
  role="region"
  aria-live="polite"
  aria-atomic="false"
  aria-relevant="additions text"
  aria-label="Notifications"
  tabindex="-1"
  style={viewportStyle}
  {...rest}
>
  <slot />
</div>

<script>
  import { createToastManager } from "@starwind-ui/runtime/toast";
  import {
    registerAstroControllerLifecycle,
    trackAstroController,
  } from "../internal/controller-lifecycle";

  const getInitCandidates = (event: Event | undefined, selector: string): HTMLElement[] => {
    const initRoot =
      event?.type === "starwind:init" && event instanceof CustomEvent
        ? event.detail?.root
        : undefined;
    const scopedRoot: Document | DocumentFragment | Element = isQueryableRoot(initRoot)
      ? initRoot
      : document;
    const candidates = Array.from(scopedRoot.querySelectorAll<HTMLElement>(selector));

    if (scopedRoot instanceof Element && scopedRoot.matches(selector)) {
      candidates.unshift(scopedRoot as HTMLElement);
    }

    return candidates;
  };

  const isQueryableRoot = (value: unknown): value is Document | DocumentFragment | Element =>
    value instanceof Document || value instanceof DocumentFragment || value instanceof Element;

  const setupToasts = (event?: Event) => {
    getInitCandidates(event, "[data-sw-toast-viewport]").forEach((viewport) => {
      trackAstroController("ToastViewport", viewport, createToastManager(viewport));
    });
  };

  registerAstroControllerLifecycle("ToastViewport", setupToasts);
</script>
