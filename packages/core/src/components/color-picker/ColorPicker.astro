---
import Background from "@tabler/icons/outline/background.svg";
import ColorPickerIcon from "@tabler/icons/outline/color-picker.svg";
import type { HTMLAttributes } from "astro/types";
import type { VariantProps } from "tailwind-variants";

import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import {
  Select,
  SelectContent,
  SelectGroup,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/starwind/select";

import { colorFormatSelect, colorInput, colorPicker, pickerContainer } from "./variants";

type ColorPickerSide = "top" | "bottom";
type ColorPickerAlign = "start" | "center" | "end";

type Props = HTMLAttributes<"input"> &
  VariantProps<typeof colorPicker> & {
    defaultValue?: string;
    /**
     * Side of the color picker
     * @default bottom
     */
    side?: ColorPickerSide;
    /**
     * Alignment of the color picker
     * @default start
     */
    align?: ColorPickerAlign;
    /**
     * Offset distance in pixels
     * @default 8
     */
    sideOffset?: number;
    /**
     * Open animation duration in milliseconds
     * @default 150
     */
    animationDuration?: number;
  };

const {
  defaultValue = "#000000",
  size,
  class: className,
  side = "bottom",
  align = "start",
  sideOffset = 8,
  animationDuration = 150,
  id,
  name,
  autocomplete,
  autofocus,
  disabled,
  form,
  list,
  max,
  min,
  pattern,
  placeholder,
  readonly,
  required,
  step,
  title,
  ...rest
} = Astro.props;

const inputProps = Object.fromEntries(
  Object.entries({
    name,
    autocomplete,
    autofocus,
    disabled,
    form,
    list,
    max,
    min,
    pattern,
    placeholder,
    readonly,
    required,
    step,
    title,
    ...Object.fromEntries(Object.entries(rest).filter(([key]) => key.startsWith("aria-"))),
  }).filter(([, value]) => value !== undefined),
);

const inputPropKeys = new Set(Object.keys(inputProps));

const containerProps = Object.fromEntries(
  Object.entries({ id, ...rest }).filter(
    ([key, value]) => value !== undefined && !inputPropKeys.has(key),
  ),
);
---

<div class={pickerContainer({ size, class: className })} {...containerProps}>
  <input
    data-state="disabled"
    data-part="color-input"
    class={colorInput({ size })}
    {...inputProps}
    type="color"
    value={defaultValue}
  />
  <div
    data-part="custom-picker"
    class={colorPicker({ size })}
    data-state="hidden"
    data-side={side}
    data-align={align}
    data-side-offset={sideOffset}
    style={{
      display: "none",
      animationDuration: `${animationDuration}ms`,
    }}
  >
    <div
      data-part="sat-rect"
      class={`sat-rect relative w-full touch-none bg-red-500 select-none ${size == "sm" ? "h-[150px]" : size == "md" ? "h-[175px]" : "h-[200px]"} mb-[20px] rounded-md border border-outline`}
    >
      <div class="absolute inset-0 rounded-[7px] bg-linear-to-r from-white to-transparent"></div>
      <div class="absolute inset-0 rounded-[7px] bg-linear-to-t from-black to-transparent"></div>
      <div
        draggable="false"
        data-part="cursor"
        class="cursor absolute top-0 left-full z-10 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-red-500"
      >
      </div>
    </div>
    <div class="relative flex items-center gap-4 px-2 has-[button]:px-0">
      <Button
        data-part="picker-btn"
        class="aspect-square h-full dark:border-none"
        aria-label="Pick a color from the screen"
        variant="outline"
        size="icon"
      >
        <ColorPickerIcon class="size-4" aria-hidden="true" />
      </Button>
      <div class="flex-1 px-2">
        <div
          data-part="hue-slider"
          class="hue-range relative mb-3 h-3 w-full touch-none rounded-md select-none"
        >
          <div
            data-part="hue-handle"
            class="hue-handle border-foreground absolute top-1/2 z-10 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 bg-red-500"
          >
          </div>
        </div>
        <div
          data-part="opacity-container"
          class="relative h-3 w-full cursor-pointer touch-none overflow-visible rounded-md select-none"
        >
          <div class="checkerboard absolute inset-0 rounded-md bg-white"></div>
          <div
            data-part="opacity-slider"
            class="absolute inset-0 rounded-md bg-linear-to-r from-transparent to-red-500"
          >
            <div
              data-part="opacity-handle"
              class="border-foreground pointer-events-none absolute top-1/2 left-full z-10 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 bg-red-500 shadow-[0_1px_3px_rgba(0,0,0,0.3)]"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class={`flex gap-2 ${size == "sm" ? "flex-col" : "flex-row items-center"} mt-5`}>
      <Select
        class={colorFormatSelect({ size })}
        required
        data-part="color-format"
        name="colorFormat"
        defaultValue="hex"
      >
        <SelectTrigger class="w-full" size="sm">
          <SelectValue class="text-nowrap" />
        </SelectTrigger>
        <SelectContent size="sm">
          <SelectGroup>
            <SelectItem value="hex" class="text-nowrap">HEX</SelectItem>
            <SelectItem value="rgb" class="text-nowrap">RGB</SelectItem>
            <SelectItem value="hsl" class="text-nowrap">HSL</SelectItem>
            <SelectItem value="hsb" class="text-nowrap">HSB</SelectItem>
          </SelectGroup>
        </SelectContent>
      </Select>
      <div class="flex">
        <Input class="input-text rounded-r-none" size="sm" />
        <Input class="input-text rounded-none" size="sm" />
        <Input class="input-text rounded-none" size="sm" />
        <Input class="input-text rounded-l-none" size="sm" />
      </div>
    </div>
    <Button data-part="none-btn" size="sm" variant="outline" class="mt-5 dark:border-none">
      <Background class="size-4" />
      None
    </Button>
  </div>
</div>

<style>
  .hue-range {
    background: linear-gradient(
      to right,
      #ff0000 0%,
      #ffff00 17%,
      #00ff00 33%,
      #00ffff 50%,
      #0000ff 67%,
      #ff00ff 83%,
      #ff0000 100%
    );
  }

  .checkerboard {
    background-image:
      linear-gradient(45deg, #ddd 25%, transparent 25%),
      linear-gradient(-45deg, #ddd 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #ddd 75%),
      linear-gradient(-45deg, transparent 75%, #ddd 75%);
    background-size: 10px 10px;
    background-position:
      0 0,
      0 5px,
      5px 5px,
      5px 0;
  }
</style>
<script>
  import {
    type FloatingAlign,
    type FloatingSide,
    getTransformOrigin,
    resolvePlacement,
  } from "@/lib/utils/starwind/positioning";
  import type { ColorPickerChangeEvent } from "./ColorPickerTypes";

  type ColorPickerFloatingSide = Extract<FloatingSide, "top" | "bottom">;
  type ColorPickerPlacement = {
    side: ColorPickerFloatingSide;
    align: FloatingAlign;
    top: number;
    left: number;
  };

  const colorPickerInstances = new WeakMap<HTMLElement, () => void>();

  function initColorPicker(container: HTMLElement): () => void {
    type UpdateOptions = {
      dispatch?: boolean;
    };

    // DOM Elements and variables
    const colorInput: HTMLInputElement | null = container.querySelector(
      '[data-part="color-input"]',
    );
    const customPicker: HTMLDivElement | null = container.querySelector(
      '[data-part="custom-picker"]',
    );
    const satRect: HTMLDivElement | null = container.querySelector('[data-part="sat-rect"]');
    const hueSlider: HTMLDivElement | null = container.querySelector('[data-part="hue-slider"]');
    const opacitySlider: HTMLDivElement | null = container.querySelector(
      '[data-part="opacity-slider"]',
    );
    const hueHandle: HTMLDivElement | null = container.querySelector('[data-part="hue-handle"]');
    const opacityHandle: HTMLDivElement | null = container.querySelector(
      '[data-part="opacity-handle"]',
    );
    const cursor: HTMLDivElement | null = container.querySelector('[data-part="cursor"]');
    const colorFormatSelect: HTMLElement | null = container.querySelector(
      '[data-part="color-format"]',
    );
    const textInputs: NodeListOf<HTMLInputElement> = container.querySelectorAll(".input-text");
    const pickerBtn: HTMLButtonElement | null = container.querySelector('[data-part="picker-btn"]');
    const noneBtn: HTMLButtonElement | null = container.querySelector('[data-part="none-btn"]');
    if (
      !colorInput ||
      !customPicker ||
      !satRect ||
      !hueSlider ||
      !opacitySlider ||
      !hueHandle ||
      !opacityHandle ||
      !cursor ||
      !colorFormatSelect ||
      !pickerBtn ||
      !noneBtn
    ) {
      return () => {};
    }
    let isDraggingHue = false;
    let isDraggingSquare = false;
    let isDraggingOpacity = false;
    let currentHue = 0;
    let currentOpacity = 100;
    let currentRgb = "255,0,0";
    let currentColorFormat = "hex";
    let isOpen = false;
    let isClosing = false;
    let contentPlaceholder: Comment | null = null;
    let portalTarget: HTMLElement | null = null;
    let cleanupAutoUpdate: (() => void) | null = null;
    let closeTimeoutRef: number | null = null;
    const abortController = new AbortController();
    const parsedSideOffset = Number(customPicker.getAttribute("data-side-offset") ?? 8);
    const sideOffset = Number.isFinite(parsedSideOffset) ? parsedSideOffset : 8;
    let animationDuration = 150;
    let side: ColorPickerFloatingSide = "bottom";
    let align: FloatingAlign = "start";
    const contentSide = customPicker.getAttribute("data-side");
    const contentAlign = customPicker.getAttribute("data-align");
    const animationDurationString = customPicker.style.animationDuration;

    if (animationDurationString.endsWith("ms")) {
      animationDuration = parseFloat(animationDurationString);
    } else if (animationDurationString.endsWith("s")) {
      animationDuration = parseFloat(animationDurationString) * 1000;
    }

    if (contentSide === "top" || contentSide === "bottom") {
      side = contentSide;
    }

    if (contentAlign === "start" || contentAlign === "center" || contentAlign === "end") {
      align = contentAlign;
    }

    colorInput.setAttribute("data-state", "enabled");

    function resolvePortalTarget(): HTMLElement {
      if (!colorInput) return document.body;
      const currentFloatingRoot = colorInput.closest("[data-floating-root]");
      if (currentFloatingRoot instanceof HTMLElement) {
        return currentFloatingRoot;
      }

      const dialogHost = colorInput.closest(
        'dialog[data-slot="dialog-content"], dialog[data-slot="sheet-content"]',
      );
      const dialogFloatingRoot = dialogHost?.querySelector(":scope > [data-floating-root]");
      if (dialogFloatingRoot instanceof HTMLElement) {
        return dialogFloatingRoot;
      }

      return document.body;
    }

    function clampPosition(value: number, min: number, max: number): number {
      return Math.min(Math.max(value, min), Math.max(min, max));
    }

    function getVerticalPlacement(options: {
      preferredSide: ColorPickerFloatingSide;
      align: FloatingAlign;
      sideOffset: number;
      triggerRect: DOMRect;
      contentWidth: number;
      contentHeight: number;
      viewportWidth: number;
      viewportHeight: number;
      viewportPadding: number;
      avoidCollisions?: boolean;
    }): ColorPickerPlacement {
      const {
        preferredSide,
        align,
        sideOffset,
        triggerRect,
        contentWidth,
        contentHeight,
        viewportWidth,
        viewportHeight,
        viewportPadding,
        avoidCollisions = true,
      } = options;
      const oppositeSide = preferredSide === "bottom" ? "top" : "bottom";
      const getTop = (placementSide: ColorPickerFloatingSide) =>
        placementSide === "bottom"
          ? triggerRect.bottom + sideOffset
          : triggerRect.top - contentHeight - sideOffset;
      const getLeft = () => {
        if (align === "end") {
          return triggerRect.right - contentWidth;
        }

        if (align === "center") {
          return triggerRect.left + (triggerRect.width - contentWidth) / 2;
        }

        return triggerRect.left;
      };

      if (!avoidCollisions) {
        return {
          side: preferredSide,
          align,
          top: getTop(preferredSide),
          left: getLeft(),
        };
      }

      const preferredTop = getTop(preferredSide);
      const oppositeTop = getTop(oppositeSide);
      const preferredFits =
        preferredTop >= viewportPadding &&
        preferredTop + contentHeight <= viewportHeight - viewportPadding;
      const oppositeFits =
        oppositeTop >= viewportPadding &&
        oppositeTop + contentHeight <= viewportHeight - viewportPadding;
      const spaceBelow = viewportHeight - triggerRect.bottom - sideOffset - viewportPadding;
      const spaceAbove = triggerRect.top - sideOffset - viewportPadding;
      const resolvedSide: ColorPickerFloatingSide = preferredFits
        ? preferredSide
        : oppositeFits
          ? oppositeSide
          : spaceBelow >= spaceAbove
            ? "bottom"
            : "top";

      return {
        side: resolvedSide,
        align,
        top: clampPosition(
          getTop(resolvedSide),
          viewportPadding,
          viewportHeight - contentHeight - viewportPadding,
        ),
        left: clampPosition(
          getLeft(),
          viewportPadding,
          viewportWidth - contentWidth - viewportPadding,
        ),
      };
    }

    function positionPicker(options?: { avoidCollisions?: boolean }) {
      if (!isOpen) return;
      if (!colorInput || !customPicker) return;

      const triggerRect = colorInput.getBoundingClientRect();
      const contentWidth = customPicker.offsetWidth;
      const contentHeight = customPicker.offsetHeight;
      const viewportPadding = 8;
      const helperPlacement = resolvePlacement({
        side,
        align,
        sideOffset,
        triggerRect,
        contentWidth,
        contentHeight,
        viewportWidth: window.innerWidth,
        viewportHeight: window.innerHeight,
        viewportPadding,
        avoidCollisions: options?.avoidCollisions ?? true,
      });
      const resolvedPlacement =
        helperPlacement.side === "top" || helperPlacement.side === "bottom"
          ? helperPlacement
          : getVerticalPlacement({
              preferredSide: side,
              align,
              sideOffset,
              triggerRect,
              contentWidth,
              contentHeight,
              viewportWidth: window.innerWidth,
              viewportHeight: window.innerHeight,
              viewportPadding,
              avoidCollisions: options?.avoidCollisions ?? true,
            });

      const portalTargetRect =
        portalTarget && portalTarget !== document.body
          ? portalTarget.getBoundingClientRect()
          : null;
      const left = portalTargetRect
        ? resolvedPlacement.left - portalTargetRect.left
        : resolvedPlacement.left;
      const top = portalTargetRect
        ? resolvedPlacement.top - portalTargetRect.top
        : resolvedPlacement.top;

      customPicker.style.left = `${Math.round(left)}px`;
      customPicker.style.top = `${Math.round(top)}px`;
      customPicker.style.transformOrigin = getTransformOrigin(
        resolvedPlacement.side,
        resolvedPlacement.align,
      );
      customPicker.setAttribute("data-side", resolvedPlacement.side);
      customPicker.setAttribute("data-align", resolvedPlacement.align);
    }

    function portalPicker() {
      if (!customPicker || !colorInput) return;
      const target = resolvePortalTarget();
      if (contentPlaceholder || customPicker.parentElement === target) return;

      contentPlaceholder = document.createComment("color-picker-placeholder");
      customPicker.parentNode?.insertBefore(contentPlaceholder, customPicker);
      target.appendChild(customPicker);
      portalTarget = target;
      customPicker.style.position = target === document.body ? "fixed" : "absolute";

      const handleScroll = () => positionPicker({ avoidCollisions: false });
      const handleResize = () => positionPicker({ avoidCollisions: true });
      window.addEventListener("scroll", handleScroll, true);
      window.addEventListener("resize", handleResize);

      const resizeObserver = new ResizeObserver(() => positionPicker({ avoidCollisions: true }));
      resizeObserver.observe(customPicker);
      resizeObserver.observe(colorInput);

      cleanupAutoUpdate = () => {
        window.removeEventListener("scroll", handleScroll, true);
        window.removeEventListener("resize", handleResize);
        resizeObserver.disconnect();
      };
    }

    function unportalPicker() {
      if (!customPicker) return;
      cleanupAutoUpdate?.();
      cleanupAutoUpdate = null;

      if (contentPlaceholder) {
        contentPlaceholder.parentNode?.insertBefore(customPicker, contentPlaceholder);
        contentPlaceholder.remove();
        contentPlaceholder = null;
      }

      portalTarget = null;
      customPicker.style.removeProperty("position");
      customPicker.style.removeProperty("top");
      customPicker.style.removeProperty("left");
      customPicker.style.removeProperty("transform-origin");
    }

    function openPicker() {
      if (!customPicker || !colorInput) return;
      if (isClosing) return;

      isOpen = true;
      customPicker.style.removeProperty("display");
      portalPicker();
      customPicker.setAttribute("data-state", "visible");
      positionPicker({ avoidCollisions: true });
      requestAnimationFrame(() => positionPicker({ avoidCollisions: true }));

      const initialValue = parseColorToRgb(colorInput.value) ?? [255, 0, 0];
      updateUIFromRGB(initialValue[0], initialValue[1], initialValue[2], { dispatch: false });
      updateOpacityValue(currentOpacity / 100, { dispatch: false });
    }

    function closePicker() {
      if (!customPicker) return;
      if (!isOpen) return;

      isClosing = true;
      isOpen = false;
      customPicker.setAttribute("data-state", "hidden");

      if (closeTimeoutRef !== null) {
        window.clearTimeout(closeTimeoutRef);
      }

      closeTimeoutRef = window.setTimeout(() => {
        closeTimeoutRef = null;
        if (abortController.signal.aborted) return;
        if (!customPicker) return;
        unportalPicker();
        customPicker.style.display = "none";
        isClosing = false;
      }, animationDuration);
    }

    function dispatchChangeEvent(value: string) {
      const event = new CustomEvent<ColorPickerChangeEvent["detail"]>(
        "starwind-color-picker:change",
        {
          detail: { value, selectId: container.id },
          bubbles: true,
          composed: true,
          cancelable: true,
        },
      );
      container.dispatchEvent(event);
    }

    function normalizeOpacity(value: number): number {
      return Number(value.toFixed(2));
    }

    // Create setValue function
    (container as any).setValue = (newRgb: string) => {
      if (isValidRGB(newRgb)) {
        const [r, g, b, a] = newRgb.split("(")[1].split(")")[0].split(",");
        updateUIFromRGB(Number(r), Number(g), Number(b), { dispatch: false });
        if (a) {
          updateOpacityValue(Number(a), { dispatch: false });
        }
        dispatchChangeEvent(container.getAttribute("value") ?? "");
      } else {
        console.error(
          `Bad format: value does not conform to the required format.  The format is "rgb(r,g,b)" or "rgba(r,g,b,a)" where r, g, b are numbers between 0 and 255 and a is a number between 0 and 1.`,
        );
      }
    };

    // Manage Color Input Trigger (prevent default picker opening and open custom picker)
    colorInput.addEventListener(
      "click",
      (e: MouseEvent) => {
        e.preventDefault();
        if (isOpen) {
          closePicker();
        } else {
          openPicker();
        }
      },
      { signal: abortController.signal },
    );

    // Manage outside click to close picker
    document.addEventListener(
      "pointerdown",
      (event: PointerEvent) => {
        const isClickInside =
          customPicker.contains(event.target as Node) || colorInput.contains(event.target as Node);

        if (!isClickInside) {
          closePicker();
        }
      },
      { signal: abortController.signal },
    );

    // Update Input Values On Color Format Change
    colorFormatSelect.addEventListener(
      "starwind-select:change",
      (event: Event) => {
        currentColorFormat = (event as ColorPickerChangeEvent).detail.value;
        updateTextInput();
      },
      { signal: abortController.signal },
    );

    // Manage None Button to unselect color
    noneBtn.addEventListener(
      "click",
      async () => {
        currentRgb = `${255},${0},${0}`;
        currentOpacity = 100;
        updateUIFromRGB(255, 0, 0, { dispatch: false });
        updateOpacityValue(1, { dispatch: false });
        colorInput.value = "";
        closePicker();
        container.setAttribute("value", "");
        dispatchChangeEvent("");
      },
      { signal: abortController.signal },
    );

    // Manage Picker Button to open eye dropper
    pickerBtn.addEventListener(
      "click",
      async () => {
        const color: string | undefined = await openEyeDropper();
        if (!color) return;
        const rgbValues = parseColorToRgb(color);
        if (!rgbValues) return;
        const [r, g, b] = rgbValues;
        currentRgb = `${r},${g},${b}`;
        updateUIFromRGB(r, g, b);
      },
      { signal: abortController.signal },
    );

    // Check if EyeDropper API is supported, if not, hide the picker button
    if (!("EyeDropper" in window)) {
      pickerBtn.style.display = "none";
    }

    // Function to Open Eye Dropper and Return Selected Color
    async function openEyeDropper(): Promise<string | undefined> {
      const eyeDropper = new (window as any).EyeDropper();

      try {
        const result = await eyeDropper.open();
        return typeof result?.sRGBHex === "string" ? result.sRGBHex : undefined;
      } catch (e) {
        if ((e as DOMException)?.name !== "AbortError") {
          console.error("EyeDropper failed:", e);
        }
        return undefined;
      }
    }

    // Manage Hue and Opacity Sliders (During Dragging)
    hueSlider.addEventListener(
      "pointerdown",
      (e: PointerEvent) => {
        e.preventDefault();
        isDraggingHue = true;
        hueSlider.setPointerCapture(e.pointerId);
        updateHue(e);
      },
      { signal: abortController.signal },
    );
    opacitySlider.addEventListener(
      "pointerdown",
      (e: PointerEvent) => {
        e.preventDefault();
        isDraggingOpacity = true;
        opacitySlider.setPointerCapture(e.pointerId);
        updateOpacity(e);
      },
      { signal: abortController.signal },
    );
    window.addEventListener(
      "pointermove",
      (e: PointerEvent) => {
        if (isDraggingHue) {
          updateHue(e);
        }
        if (isDraggingOpacity) {
          updateOpacity(e);
        }
        if (isDraggingSquare) {
          moveCursor(e);
        }
      },
      { signal: abortController.signal },
    );
    window.addEventListener(
      "pointerup",
      () => {
        isDraggingHue = false;
        isDraggingOpacity = false;
        isDraggingSquare = false;
      },
      { signal: abortController.signal },
    );
    window.addEventListener(
      "pointercancel",
      () => {
        isDraggingHue = false;
        isDraggingOpacity = false;
        isDraggingSquare = false;
      },
      { signal: abortController.signal },
    );

    // Manage Main Color Square (During Dragging)
    satRect.addEventListener(
      "pointerdown",
      (e: PointerEvent) => {
        e.preventDefault();
        isDraggingSquare = true;
        satRect.setPointerCapture(e.pointerId);
        moveCursor(e);
      },
      { signal: abortController.signal },
    );

    function moveCursor(e: PointerEvent) {
      if (!satRect || !cursor) return;
      const rect = satRect.getBoundingClientRect();
      let x = e.clientX - rect.left;
      let y = e.clientY - rect.top;

      // Keep cursor inside bounds
      x = Math.max(0, Math.min(x, rect.width));
      y = Math.max(0, Math.min(y, rect.height));

      cursor.style.left = `${x}px`;
      cursor.style.top = `${y}px`;

      const h = currentHue;
      const s = (x / rect.width) * 100;
      const v = 100 - (y / rect.height) * 100;

      const finalColor = hsvToRgb(h, s, v);
      const [r, g, b] = finalColor.split("(")[1].split(")")[0].split(",");

      setSelectedColor(Number(r), Number(g), Number(b));
    }

    // Update UI and Manage Colors

    // Manage Hue Slider (During Dragging)
    function updateHue(e: PointerEvent) {
      if (!hueSlider || !hueHandle) return;
      const rect = hueSlider.getBoundingClientRect();

      // Calculate position relative to the slider
      let x = e.clientX - rect.left;

      // Constrain the value between 0 and the slider width
      x = Math.max(0, Math.min(x, rect.width));

      // Convert to percentage (0 - 100)
      const percent = (x / rect.width) * 100;

      // Update UI (Move handle and change color)
      hueHandle.style.left = `${x}px`;

      // Hue is 0-360 degrees
      const hue = (percent / 100) * 360;
      updateMainSquareColor(hue);
    }

    // Select Main Color and Update UI
    function setSelectedColor(r: number, g: number, b: number, options: UpdateOptions = {}) {
      if (!cursor || !opacitySlider || !opacityHandle || !colorInput) return;
      if (!areRgbValuesValid(r, g, b)) return;
      const { dispatch = true } = options;
      const alpha = normalizeOpacity(currentOpacity / 100);
      const finalColor =
        currentOpacity != 100 ? `rgba(${r},${g},${b}, ${alpha})` : `rgb(${r},${g},${b})`;
      cursor.style.backgroundColor = finalColor;
      currentRgb = `${r},${g},${b}`;
      const rgb = `${r},${g},${b}`;
      opacitySlider.style.background = `linear-gradient(to right, rgba(${rgb}, 0) 0%, rgba(${rgb}, 1) 100%)`;
      opacityHandle.style.backgroundColor = `rgba(${rgb}, ${alpha})`;
      colorInput.value = rgbToHex(r, g, b);
      container.setAttribute("value", finalColor);
      if (dispatch) {
        dispatchChangeEvent(finalColor);
      }
      updateTextInput();
    }

    // Update Main Square Color and Cursor Position (During Dragging)
    function updateMainSquareColor(hue: number) {
      if (!satRect || !hueHandle || !cursor) return;
      // 1. Update the background color of the square
      // This represents the "Pure" version of the selected Hue
      const pureColor = `hsl(${hue}, 100%, 50%)`;
      satRect.style.backgroundColor = pureColor;
      hueHandle.style.backgroundColor = pureColor;
      currentHue = hue;

      // 2. Get the cursor's current position to calculate Saturation and Value
      const rect = satRect.getBoundingClientRect();
      const cursorLeft = parseFloat(cursor.style.left) || 0;
      const cursorTop = parseFloat(cursor.style.top) || 0;
      const s = (cursorLeft / rect.width) * 100;
      const v = 100 - (cursorTop / rect.height) * 100;

      const finalColor = hsvToRgb(hue, s, v);
      const [r, g, b] = finalColor.split("(")[1].split(")")[0].split(",");

      setSelectedColor(Number(r), Number(g), Number(b));
    }

    // Update Opacity (During Dragging)
    function updateOpacity(e: PointerEvent) {
      if (!opacitySlider || !opacityHandle || !colorInput) return;
      const rect = opacitySlider.getBoundingClientRect();
      let x = e.clientX - rect.left;

      // Constrain position
      x = Math.max(0, Math.min(x, rect.width));

      // Update handle position UI
      opacityHandle.style.left = `${x}px`;

      // Calculate the percentage (0 to 1)
      const opacityPercentage = normalizeOpacity(x / rect.width);

      // Store as 0–100 for easy state reading
      currentOpacity = Math.round(opacityPercentage * 100);
      const rgb = currentRgb;
      opacityHandle.style.backgroundColor = `rgba(${rgb}, ${opacityPercentage})`;
      colorInput.style.opacity = opacityPercentage.toString();
      container.setAttribute(
        "value",
        currentOpacity != 100 ? `rgba(${rgb}, ${opacityPercentage})` : `rgb(${rgb})`,
      );
      dispatchChangeEvent(
        currentOpacity != 100 ? `rgba(${rgb}, ${opacityPercentage})` : `rgb(${rgb})`,
      );
      updateTextInput();
    }

    // Update Opacity with Value (Directly)
    function updateOpacityValue(value: number, options: UpdateOptions = {}) {
      if (!opacityHandle || !opacitySlider || !colorInput) return;
      const { dispatch = true } = options;
      const normalizedValue = normalizeOpacity(value);
      currentOpacity = normalizedValue * 100;
      const rgb = currentRgb;
      opacityHandle.style.backgroundColor = `rgba(${rgb}, ${normalizedValue})`;
      const rect = opacitySlider.getBoundingClientRect();
      let x = rect.width * normalizedValue;
      x = Math.max(0, Math.min(x, rect.width));
      opacityHandle.style.left = `${x}px`;
      colorInput.style.opacity = normalizedValue.toString();
      container.setAttribute(
        "value",
        currentOpacity != 100 ? `rgba(${rgb}, ${normalizedValue})` : `rgb(${rgb})`,
      );
      if (dispatch) {
        dispatchChangeEvent(
          currentOpacity != 100 ? `rgba(${rgb}, ${normalizedValue})` : `rgb(${rgb})`,
        );
      }
      updateTextInput();
    }

    // Update Text Input Values After Selected Color Changes
    function updateTextInput() {
      const rgb = currentRgb;
      const [r, g, b] = rgb.split(",");
      if (currentColorFormat == "rgb") {
        textInputs[0].value = r;
        textInputs[1].value = g;
        textInputs[2].value = b;
        textInputs[3].value = Number(currentOpacity / 100).toFixed(2);
      } else if (currentColorFormat == "hex") {
        const hex = rgbToHex(Number(r), Number(g), Number(b)).slice(1);
        textInputs[0].value = hex.slice(0, 2) != "NaN" ? hex.slice(0, 2) : "00";
        textInputs[1].value = hex.slice(2, 4) != "NaN" ? hex.slice(2, 4) : "00";
        textInputs[2].value = hex.slice(4, 6) != "NaN" ? hex.slice(4, 6) : "00";
        textInputs[3].value = decimalOpacityToHex(currentOpacity) || "00";
      } else if (currentColorFormat == "hsb") {
        const [hsbR, hsbG, hsbB] = rgbToHsb(Number(r), Number(g), Number(b));
        textInputs[0].value = String(hsbR);
        textInputs[1].value = String(hsbG);
        textInputs[2].value = String(hsbB);
        textInputs[3].value = Number(currentOpacity / 100).toFixed(2);
      } else if (currentColorFormat == "hsl") {
        const [hslR, hslG, hslB] = rgbToHsl(Number(r), Number(g), Number(b));
        textInputs[0].value = String(hslR);
        textInputs[1].value = String(hslG);
        textInputs[2].value = String(hslB);
        textInputs[3].value = Number(currentOpacity / 100).toFixed(2);
      }
    }

    // Update UI After Selected Color Changes
    function updateUIFromRGB(r: number, g: number, b: number, options: UpdateOptions = {}) {
      if (!satRect || !hueHandle || !cursor || !hueSlider) return;
      const [h, s, v] = rgbToHsb(r, g, b);

      const rect = satRect.getBoundingClientRect();

      // 2. Update Global State
      currentHue = h;

      // 3. Update Saturation Square background
      const pureColor = `hsl(${h}, 100%, 50%)`;
      satRect.style.backgroundColor = pureColor;
      hueHandle.style.backgroundColor = pureColor;

      // 4. Update Cursor Position (The Reverse Math)
      const x = (s / 100) * rect.width;
      const y = (1 - v / 100) * rect.height;

      cursor.style.left = `${x}px`;
      cursor.style.top = `${y}px`;

      // 5. Update Hue Slider Position
      const huePercent = h / 360;
      const trackWidth = hueSlider.offsetWidth;
      hueHandle.style.left = `${huePercent * trackWidth}px`;

      // 6. Finally, update the color input value
      setSelectedColor(r, g, b, options);
    }

    // Before Input Logic (Prevent invalid inputs)
    const isHexInputValid = (data: string, value: string) => {
      const regex = /[0-9a-fA-F]/;
      return value.length <= 1 && regex.test(data);
    };

    const isRgbInputValid = (data: string, value: string) => {
      const regex = /[0-9]/;
      return (
        value.length <= 2 &&
        regex.test(data) &&
        Number(`${value}${data}`) < 256 &&
        Number(`${value}${data}`) >= 0
      );
    };

    const isHsbHslValid = (data: string, value: string, index: number) => {
      const regex = /[0-9]/;
      return (
        value.length <= 2 &&
        regex.test(data) &&
        (index != 0 || Number(`${value}${data}`) <= 360) &&
        (index == 0 || Number(`${value}${data}`) <= 100) &&
        Number(`${value}${data}`) >= 0
      );
    };

    const isOpacityValueValid = (value: string): boolean => {
      const normalizedValue = value.trim();
      if (!/^(0(?:\.\d+)?|1(?:\.0+)?)$/.test(normalizedValue)) {
        return false;
      }

      const parsedValue = Number(normalizedValue);
      return Number.isFinite(parsedValue) && parsedValue >= 0 && parsedValue <= 1;
    };

    textInputs.forEach((input: HTMLInputElement, inputIndex: number) =>
      input.addEventListener(
        "beforeinput",
        (e: InputEvent) => {
          const target = e.target as HTMLInputElement;
          const futureValue: string =
            target.value.slice(0, target.selectionStart ?? 0) +
            (e.data || "") +
            target.value.slice(target.selectionEnd ?? 0);
          if (e.data) {
            if (inputIndex == 3 && currentColorFormat != "hex") {
              if (!isOpacityValueValid(futureValue)) {
                e.preventDefault();
              }
              return;
            }
            if (currentColorFormat == "hex" && !isHexInputValid(e.data, target.value)) {
              e.preventDefault();
            } else if (currentColorFormat == "rgb" && !isRgbInputValid(e.data, target.value)) {
              e.preventDefault();
            } else if (
              ["hsb", "hsl"].includes(currentColorFormat) &&
              !isHsbHslValid(e.data, target.value, inputIndex)
            ) {
              e.preventDefault();
            }
          }
        },
        { signal: abortController.signal },
      ),
    );

    // Input Change Logic (Update selector ui and value on input)
    textInputs.forEach((input: HTMLInputElement, inputIndex: number) =>
      input.addEventListener(
        "change",
        (e: Event) => {
          const changeTarget = e.target as HTMLInputElement;
          if (inputIndex == 3) {
            const value =
              currentColorFormat == "hex"
                ? hexOpacityToDecimal(changeTarget.value)
                : isOpacityValueValid(changeTarget.value)
                  ? Number(changeTarget.value)
                  : NaN;
            if (!Number.isFinite(value)) {
              updateTextInput();
              return;
            }
            updateOpacityValue(value);
            return;
          }
          let rgbValues: [number, number, number];
          if (currentColorFormat == "rgb") {
            const rgb = currentRgb;
            rgbValues = rgb.split(",").map(Number) as [number, number, number];
            rgbValues[inputIndex] = Number(changeTarget.value);
          } else if (currentColorFormat == "hex") {
            const parsedHex = parseColorToRgb(
              `#${textInputs[0].value}${textInputs[1].value}${textInputs[2].value}`,
            );
            if (!parsedHex) return;
            rgbValues = parsedHex;
          } else if (currentColorFormat == "hsb") {
            rgbValues = hsbToRgb(
              Number(textInputs[0].value),
              Number(textInputs[1].value),
              Number(textInputs[2].value),
            );
          } else if (currentColorFormat == "hsl") {
            rgbValues = hslToRgb(
              Number(textInputs[0].value),
              Number(textInputs[1].value),
              Number(textInputs[2].value),
            );
          } else {
            rgbValues = [0, 0, 0];
          }
          updateUIFromRGB(rgbValues[0], rgbValues[1], rgbValues[2]);
        },
        { signal: abortController.signal },
      ),
    );

    // Translate Color Format Functions
    const areRgbValuesValid = (...values: number[]): boolean =>
      values.every((value) => Number.isFinite(value) && value >= 0 && value <= 255);

    const parseColorToRgb = (color: string): [number, number, number] | undefined => {
      const normalized = color.trim();
      if (!normalized) return undefined;

      const rgbMatch = normalized.match(/^rgba?\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/i);
      if (rgbMatch) {
        const rgbValues = rgbMatch.slice(1, 4).map(Number) as [number, number, number];
        return areRgbValuesValid(...rgbValues) ? rgbValues : undefined;
      }

      return hexToRgb(normalized);
    };

    const rgbToHex = (r: number, g: number, b: number): string => {
      if (!areRgbValuesValid(r, g, b)) return "#000000";
      const [hexR, hexG, hexB] = [r, g, b].map((code) => {
        const hex = Math.round(code).toString(16);
        return hex.length === 1 ? "0" + hex : hex;
      });
      return `#${hexR}${hexG}${hexB}`;
    };

    function hexToRgb(hex: string): [number, number, number] | undefined {
      hex = hex.trim().replace(/^#/, "");

      if (![3, 6].includes(hex.length) || !/^[0-9a-fA-F]+$/.test(hex)) {
        return undefined;
      }

      if (hex.length === 3) {
        hex = hex
          .split("")
          .map((char) => char + char)
          .join("");
      }

      const r = parseInt(hex.substring(0, 2), 16);
      const g = parseInt(hex.substring(2, 4), 16);
      const b = parseInt(hex.substring(4, 6), 16);

      return areRgbValuesValid(r, g, b) ? [r, g, b] : undefined;
    }

    function decimalOpacityToHex(opacity: number): string {
      const percent = Math.max(0, Math.min(100, opacity)); // Ensure opacity is between 0 and 100
      const intValue = Math.round(percent * 2.55); // Map 0-100 to 0-255
      const hex = intValue.toString(16).padStart(2, "0");
      return hex;
    }
    function hexOpacityToDecimal(hexAlpha: string): number {
      const cleanHex = hexAlpha.replace("#", "");
      const alphaPart = cleanHex.length > 2 ? cleanHex.slice(-2) : cleanHex;

      const intValue = parseInt(alphaPart, 16);

      if (isNaN(intValue)) return 1; // Default to fully opaque if invalid

      return parseFloat((intValue / 255).toFixed(2));
    }

    function isValidRGB(color: string): boolean {
      const regex = /^rgba?\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*(?:,\s*([\d.]+)\s*)?\)$/i;
      const match = color.match(regex);

      if (!match) return false;

      const [r, g, b, a] = match.slice(1).map(Number);

      const rgbValid = [r, g, b].every((val) => !isNaN(val) && val >= 0 && val <= 255);

      const hasAlpha = match[4] !== undefined;
      const alphaValid = !hasAlpha || (a >= 0 && a <= 1);

      return rgbValid && alphaValid;
    }

    function rgbToHsl(r: number, g: number, b: number): [number, number, number] {
      r /= 255;
      g /= 255;
      b /= 255;

      const max = Math.max(r, g, b),
        min = Math.min(r, g, b);
      let h = 0,
        s_hsl = 0;
      const l = (max + min) / 2;

      const d = max - min;

      if (max === min) {
        h = s_hsl = 0;
      } else {
        switch (max) {
          case r:
            h = (g - b) / d + (g < b ? 6 : 0);
            break;
          case g:
            h = (b - r) / d + 2;
            break;
          case b:
            h = (r - g) / d + 4;
            break;
        }
        h /= 6;

        s_hsl = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      }

      return [Math.round(h * 360), Math.round(s_hsl * 100), Math.round(l * 100)];
    }

    function hslToRgb(h: number, s: number, l: number): [number, number, number] {
      const sNorm = s / 100;
      const lNorm = l / 100;

      const a = sNorm * Math.min(lNorm, 1 - lNorm);
      const k = (n: number) => (n + h / 30) % 12;
      const f = (n: number) => lNorm - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));

      return [Math.round(255 * f(0)), Math.round(255 * f(8)), Math.round(255 * f(4))];
    }

    function rgbToHsb(r: number, g: number, b: number): [number, number, number] {
      r /= 255;
      g /= 255;
      b /= 255;

      const max = Math.max(r, g, b),
        min = Math.min(r, g, b);
      let h = 0;
      let s_hsb = 0;
      const v = max; // v is Brightness/Value

      const d = max - min;

      if (max === min) {
        h = s_hsb = 0;
      } else {
        switch (max) {
          case r:
            h = (g - b) / d + (g < b ? 6 : 0);
            break;
          case g:
            h = (b - r) / d + 2;
            break;
          case b:
            h = (r - g) / d + 4;
            break;
        }
        h /= 6;
        s_hsb = max === 0 ? 0 : d / max;
      }

      return [Math.round(h * 360), Math.round(s_hsb * 100), Math.round(v * 100)];
    }

    function hsbToRgb(h: number, s: number, b: number): [number, number, number] {
      const sNorm = s / 100;
      const bNorm = b / 100;

      const k = (n: number) => (n + h / 60) % 6;
      const f = (n: number) => bNorm * (1 - sNorm * Math.max(0, Math.min(k(n), 4 - k(n), 1)));

      return [Math.round(255 * f(5)), Math.round(255 * f(3)), Math.round(255 * f(1))];
    }

    function hsvToRgb(h: number, s: number, v: number): string {
      s /= 100;
      v /= 100;
      const k = (n: number) => (n + h / 60) % 6;
      const f = (n: number) => v * (1 - s * Math.max(0, Math.min(k(n), 4 - k(n), 1)));

      const r = Math.round(255 * f(5));
      const g = Math.round(255 * f(3));
      const b = Math.round(255 * f(1));

      return `rgb(${r}, ${g}, ${b})`;
    }

    return () => {
      abortController.abort();
      if (closeTimeoutRef !== null) {
        window.clearTimeout(closeTimeoutRef);
        closeTimeoutRef = null;
      }
      closePicker();
      unportalPicker();
      customPicker.style.display = "none";
      isClosing = false;
    };
  }

  function initColorPickers() {
    document.querySelectorAll<HTMLElement>(".starwind-color-picker").forEach((colorPicker) => {
      if (!colorPickerInstances.has(colorPicker)) {
        colorPickerInstances.set(colorPicker, initColorPicker(colorPicker));
      }
    });
  }

  function destroyColorPickers() {
    document.querySelectorAll<HTMLElement>(".starwind-color-picker").forEach((colorPicker) => {
      const destroy = colorPickerInstances.get(colorPicker);
      destroy?.();
      colorPickerInstances.delete(colorPicker);
    });
  }

  initColorPickers();
  document.addEventListener("astro:before-swap", destroyColorPickers);
  document.addEventListener("astro:after-swap", initColorPickers);
  document.addEventListener("starwind:init", initColorPickers);
</script>
