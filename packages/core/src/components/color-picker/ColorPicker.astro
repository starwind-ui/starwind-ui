---
import Background from "@tabler/icons/outline/background.svg";
import ColorPickerIcon from "@tabler/icons/outline/color-picker.svg";
import type { HTMLAttributes } from "astro/types";
import { tv, type VariantProps } from "tailwind-variants";

import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import {
  Select,
  SelectContent,
  SelectGroup,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/starwind/select";

type Props = HTMLAttributes<"input"> &
  VariantProps<typeof colorPicker> & {
    defaultValue?: string;
  };

export const colorInput = tv({
  base: [
    "border-input dark:bg-input/30 text-foreground pointer-events-none absolute h-full w-full cursor-pointer appearance-none rounded-md border border-none bg-transparent bg-none p-0 shadow-xs",
    "[&::-moz-color-swatch]:border-none [&::-webkit-color-swatch]:border-none [&::-webkit-color-swatch-wrapper]:p-0",
    "focus-visible:border-outline focus-visible:ring-outline/50 transition-[color,box-shadow] focus-visible:ring-3",
    "disabled:cursor-not-allowed disabled:opacity-50",
    "data-[state=enabled]:pointer-events-auto data-[state=disabled]:pointer-events-none",
    "aria-invalid:border-error aria-invalid:focus-visible:ring-error/40",
    "peer placeholder:text-muted-foreground",
  ],
  variants: {
    size: { sm: "rounded-[5px]", md: "rounded-sm", lg: "rounded-md" },
  },
  defaultVariants: { size: "md" },
});

export const colorPicker = tv({
  base: [
    "custom-picker bg-card absolute w-100 rounded-md border",
    "data-[state=hidden]:hidden data-[state=hidden]:z-0 data-[state=visible]:block data-[state=visible]:!z-20",
    "data-[position-x=left]:left-0 data-[position-x=right]:right-0",
    "data-[position-y=top]:top-full data-[position-y=bottom]:bottom-full",
    "data-[position-y=top]:mt-2 data-[position-y=bottom]:mb-2",
  ],
  variants: {
    size: { sm: "w-60 p-3", md: "w-80 p-4", lg: "w-100 p-5" },
  },
  defaultVariants: { size: "md" },
});

export const pickerContainer = tv({
  base: ["picker-container", "border-input relative isolate- rounded-[9.5px]"],
  variants: {
    size: {
      sm: "h-5 w-5 rounded-[5.5px] border",
      md: "h-7 w-7 rounded-[7.5px] border-2",
      lg: "h-9 w-9 rounded-[10.5px] border-3",
    },
  },
  defaultVariants: { size: "md" },
});

export const colorFormatSelect = tv({
  base: ["flex min-w-22 overflow-y-visible"],
  variants: {
    size: { sm: "min-w-18", md: "min-w-20", lg: "min-w-22" },
  },
  defaultVariants: { size: "md" },
});

const { defaultValue = "#000000", size, class: className, ...rest } = Astro.props;
---

<div class={pickerContainer({ size, class: className })} {...rest}>
  <input
    data-state="disabled"
    id="color-input"
    class={colorInput({ size })}
    {...rest}
    type="color"
    value={defaultValue}
  />
  <div id="custom-picker" class={colorPicker({ size })} data-state="hidden" data-position-x="right" data-position-y="bottom">
    <div
      id="sat-rect"
      class={`sat-rect relative w-full bg-red-500 ${size == "sm" ? "h-[150px]" : size == "md" ? "h-[175px]" : "h-[200px]"} mb-[20px] rounded-md border border-outline`}
    >
      <div class="absolute inset-0 rounded-[7px] bg-linear-to-r from-white to-transparent"></div>
      <div class="absolute inset-0 rounded-[7px] bg-linear-to-t from-black to-transparent"></div>
      <div
        draggable="false"
        id="cursor"
        class="cursor absolute top-0 left-full z-10 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-red-500"
      >
      </div>
    </div>
    <div class="relative flex items-center gap-4 has-[button]:px-0 px-2">
      <Button
        id="picker-btn"
        class="aspect-square h-full dark:border-none"
        variant="outline"
        size="icon"
      >
        <ColorPickerIcon class="size-4" />
      </Button>
      <div class="flex-1 px-2">
        <div id="hue-slider" class="hue-range relative mb-3 h-3 w-full rounded-md">
          <div
            id="hue-handle"
            class="hue-handle border-foreground absolute top-1/2 z-10 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 bg-red-500"
          >
          </div>
        </div>
        <div
          id="opacity-container"
          class="relative h-3 w-full cursor-pointer overflow-visible rounded-md"
        >
          <div class="checkerboard absolute inset-0 rounded-md bg-white"></div>
          <div
            id="opacity-slider"
            class="absolute inset-0 rounded-md bg-linear-to-r from-transparent to-red-500"
          >
            <div
              id="opacity-handle"
              class="border-foreground pointer-events-none absolute top-1/2 left-full z-10 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 bg-red-500 shadow-[0_1px_3px_rgba(0,0,0,0.3)]"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class={`flex gap-2 ${size == "sm" ? "flex-col" : "flex-row items-center"} mt-5`}>
      <Select
        class={colorFormatSelect({ size })}
        required
        id="colorFormat"
        name="colorFormat"
        defaultValue="hex"
      >
        <SelectTrigger class="w-full" size="sm">
          <SelectValue class="text-nowrap" />
        </SelectTrigger>
        <SelectContent size="sm">
          <SelectGroup>
            <SelectItem value="hex" class="text-nowrap">HEX</SelectItem>
            <SelectItem value="rgb" class="text-nowrap">RGB</SelectItem>
            <SelectItem value="hsl" class="text-nowrap">HSL</SelectItem>
            <SelectItem value="hsb" class="text-nowrap">HSB</SelectItem>
          </SelectGroup>
        </SelectContent>
      </Select>
      <div class="flex">
        <Input class="input-text rounded-r-none" size="sm" />
        <Input class="input-text rounded-none" size="sm" />
        <Input class="input-text rounded-none" size="sm" />
        <Input class="input-text rounded-l-none" size="sm" />
      </div>
    </div>
    <Button id="none-btn" size="sm" variant="outline" class="mt-5 dark:border-none">
      <Background class="size-4" />
      None
    </Button>
  </div>
</div>

<style>
  .hue-range {
    background: linear-gradient(
      to right,
      #ff0000 0%,
      #ffff00 17%,
      #00ff00 33%,
      #00ffff 50%,
      #0000ff 67%,
      #ff00ff 83%,
      #ff0000 100%
    );
  }

  .checkerboard {
    background-image:
      linear-gradient(45deg, #ddd 25%, transparent 25%),
      linear-gradient(-45deg, #ddd 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #ddd 75%),
      linear-gradient(-45deg, transparent 75%, #ddd 75%);
    background-size: 10px 10px;
    background-position:
      0 0,
      0 5px,
      5px 5px,
      5px 0;
  }
</style>
<script>
  import type { ColorPickerChangeEvent } from "./ColorPickerTypes";
  document.querySelectorAll(".picker-container").forEach((el: HTMLElement) => {
    initColorPicker(el);
  });
  function initColorPicker(container: HTMLElement) {
    // DOM Elements and variables
    const colorInput: HTMLInputElement | null = container.querySelector("#color-input");
    const customPicker: HTMLDivElement | null = container.querySelector("#custom-picker");
    const satRect: HTMLDivElement | null = container.querySelector("#sat-rect");
    const hueSlider: HTMLDivElement | null = container.querySelector("#hue-slider");
    const opacitySlider: HTMLDivElement | null = container.querySelector("#opacity-slider");
    const hueHandle: HTMLDivElement | null = container.querySelector("#hue-handle");
    const opacityHandle: HTMLDivElement | null = container.querySelector("#opacity-handle");
    const cursor: HTMLDivElement | null = container.querySelector("#cursor");
    const colorFormatSelect: HTMLSelectElement | null = container.querySelector("#colorFormat");
    const textInputs: NodeListOf<HTMLInputElement> = container.querySelectorAll(".input-text");
    const pickerBtn: HTMLButtonElement | null = container.querySelector("#picker-btn");
    const noneBtn: HTMLButtonElement | null = container.querySelector("#none-btn");
    let isDraggingHue = false;
    let isDraggingSquare = false;
    let isDraggingOpacity = false;
    let currentHue = 0;
    let currentOpacity = 100;
    let currentRgb = "rgb(255,0,0)";
    let currentColorFormat = "hex";

    colorInput.setAttribute('data-state', 'enabled');

    // Create setValue function
    container.setValue = (newRgb: string) => {
      if (isValidRGB(newRgb)) {
        const [r, g, b, a] = newRgb.split("(")[1].split(")")[0].split(",");
        updateUIFromRGB(r, g, b);
        if (a) {
          updateOpacityValue(a);
        }
      } else {
        console.error(
          `Bad format: value does not conform to the required format.  The format is "rgb(r,g,b)" or "rgba(r,g,b,a)" where r, g, b are numbers between 0 and 255 and a is a number between 0 and 1.`,
        );
      }
    };

    // Manage Color Input Trigger (prevent default picker opening and open custom picker)
    colorInput.addEventListener("click", (e: MouseEvent) => {
      e.preventDefault();
      const button = e.currentTarget.getBoundingClientRect();
      const pickerHeight = 410;
      const pickerWidth = 410;
      const spaceVerticalAbove = button.top;
      const spaceVerticalBelow = window.innerHeight - button.bottom;
      const spaceHorizontalBelow = window.innerWidth - button.right;
      const spaceHorizontalAbove = button.left;
      // Based on space (vertical and horizontall) depends on where to open the picker
      if (spaceVerticalBelow < pickerHeight && spaceVerticalAbove > pickerHeight) {
        customPicker.setAttribute('data-position-y', 'bottom');
      } else {
        customPicker.setAttribute('data-position-y', 'top');
      }
      if (spaceHorizontalBelow < pickerWidth && spaceHorizontalAbove > pickerWidth) {
        customPicker.setAttribute('data-position-x', 'right');
      } else {
        customPicker.setAttribute('data-position-x', 'left');
      }
      customPicker.setAttribute('data-state', customPicker.getAttribute('data-state') === 'hidden' ? 'visible' : 'hidden');

      const initialValue = hexToRgb(colorInput.value);
      updateUIFromRGB(initialValue[0], initialValue[1], initialValue[2]);
      updateOpacityValue(currentOpacity / 100);
    });

    // Manage outside click to close picker
    document.addEventListener("mousedown", (event: MouseEvent) => {
      const isClickInside =
        customPicker.contains(event.target) || colorInput.contains(event.target);

      if (!isClickInside) {
        customPicker.setAttribute('data-state', 'hidden');
      }
    });

    // Update Input Values On Color Format Change
    colorFormatSelect.addEventListener("starwind-select:change", (event: ColorPickerChangeEvent) => {
      currentColorFormat = event.detail.value;
      updateTextInput();
    });

    // Manage None Button to unselect color
    noneBtn.addEventListener("click", async () => {
      currentRgb = `rgb(${255},${0},${0})`;
      currentOpacity = 100;
      updateUIFromRGB(255, 0, 0);
      updateOpacityValue(1);
      colorInput.value = null;
      customPicker.setAttribute('data-state', 'hidden');
      container.setAttribute("value", null);
    });

    // Manage Picker Button to open eye dropper
    pickerBtn.addEventListener("click", async () => {
      const color: string | undefined = await openEyeDropper();
      if (!color) return;
      const [r, g, b] = hexToRgb(color);
      currentRgb = `rgb(${r},${g},${b})`;
      updateUIFromRGB(r, g, b);
    });

    // Check if EyeDropper API is supported, if not, hide the picker button
    if (!window.EyeDropper) {
      console.error("Your browser does not support the EyeDropper API");
      pickerBtn.style.display = "none";
    }

    // Function to Open Eye Dropper and Return Selected Color
    async function openEyeDropper(): Promise<string | undefined> {
      const eyeDropper = new EyeDropper();

      try {
        const result = await eyeDropper.open();
        return result.sRGBHex;
      } catch (e) {
        console.error("Color selection cancelled");
      }
    }

    // Manage Hue and Opacity Sliders (During Dragging)
    hueSlider.addEventListener("mousedown", (e: MouseEvent) => {
      e.preventDefault();
      isDraggingHue = true;
      updateHue(e);
    });
    opacitySlider.addEventListener("mousedown", (e: MouseEvent) => {
      e.preventDefault();
      isDraggingOpacity = true;
      updateOpacity(e);
    });
    window.addEventListener("mousemove", (e: MouseEvent) => {
      if (isDraggingHue) {
        updateHue(e);
      }
      if (isDraggingOpacity) {
        updateOpacity(e);
      }
    });
    window.addEventListener("mouseup", () => {
      isDraggingHue = false;
      isDraggingOpacity = false;
      isDraggingSquare = false;
    });

    // Manage Main Color Square (During Dragging)
    satRect.addEventListener("mousedown", (e: MouseEvent) => {
      e.preventDefault();
      isDraggingSquare = true;
      moveCursor(e);
    });

    window.addEventListener("mousemove", (e: MouseEvent) => {
      if (isDraggingSquare) moveCursor(e);
    });

    function moveCursor(e: MouseEvent) {
      const rect = satRect.getBoundingClientRect();
      let x = e.clientX - rect.left;
      let y = e.clientY - rect.top;

      // Keep cursor inside bounds
      x = Math.max(0, Math.min(x, rect.width));
      y = Math.max(0, Math.min(y, rect.height));

      cursor.style.left = `${x}px`;
      cursor.style.top = `${y}px`;

      const h = currentHue;
      const s = (x / rect.width) * 100;
      const v = 100 - (y / rect.height) * 100;

      const finalColor = hsvToRgb(h, s, v);
      const [r, g, b] = finalColor.split("(")[1].split(")")[0].split(",");

      setSelectedColor(r, g, b);
    }

    // Update UI and Manage Colors

    // Manage Hue Slider (During Dragging)
    function updateHue(e: MouseEvent) {
      const rect = hueSlider.getBoundingClientRect();

      // Calculate position relative to the slider
      let x = e.clientX - rect.left;

      // Constrain the value between 0 and the slider width
      x = Math.max(0, Math.min(x, rect.width));

      // Convert to percentage (0 - 100)
      const percent = (x / rect.width) * 100;

      // Update UI (Move handle and change color)
      hueHandle.style.left = `${x}px`;

      // Hue is 0-360 degrees
      const hue = (percent / 100) * 360;
      updateMainSquareColor(hue);
    }

    // Select Main Color and Update UI
    function setSelectedColor(r: number, g: number, b: number) {
      const finalColor =
        currentOpacity != 100
          ? `rgba(${r},${g},${b}, ${currentOpacity / 100})`
          : `rgb(${r},${g},${b})`;
      cursor.style.backgroundColor = finalColor;
      currentRgb = finalColor;
      const rgb = `${r},${g},${b}`;
      opacitySlider.style.background = `linear-gradient(to right, rgba(${rgb}, 0) 0%, rgba(${rgb}, 1) 100%)`;
      opacityHandle.style.backgroundColor = `rgba(${rgb}, ${currentOpacity / 100})`;
      colorInput.value = rgbToHex(r, g, b);
      container.setAttribute("value", finalColor);
      const event = new CustomEvent<ColorPickerChangeEvent["detail"]>(
        "starwind-color-picker:change",
        {
          detail: { value: finalColor, selectId: container.id },
          bubbles: true,
          composed: true,
          cancelable: true,
        },
      );
      container.dispatchEvent(event);
      updateTextInput();
    }

    // Update Main Square Color and Cursor Position (During Dragging)
    function updateMainSquareColor(hue: number) {
      // 1. Update the background color of the square
      // This represents the "Pure" version of the selected Hue
      const pureColor = `hsl(${hue}, 100%, 50%)`;
      satRect.style.backgroundColor = pureColor;
      hueHandle.style.backgroundColor = pureColor;
      currentHue = hue;

      // 2. Get the cursor's current position to calculate Saturation and Value
      const rect = satRect.getBoundingClientRect();
      const cursorLeft = parseFloat(cursor.style.left) || 0;
      const cursorTop = parseFloat(cursor.style.top) || 0;
      const s = (cursorLeft / rect.width) * 100;
      const v = 100 - (cursorTop / rect.height) * 100;

      const finalColor = hsvToRgb(hue, s, v);
      const [r, g, b] = finalColor.split("(")[1].split(")")[0].split(",");

      setSelectedColor(r, g, b);
    }

    // Update Opacity (During Dragging)
    function updateOpacity(e: MouseEvent) {
      const rect = opacitySlider.getBoundingClientRect();
      let x = e.clientX - rect.left;

      // Constrain position
      x = Math.max(0, Math.min(x, rect.width));

      // Update handle position UI
      opacityHandle.style.left = `${x}px`;

      // Calculate the percentage (0 to 1)
      const opacityPercentage = x / rect.width;

      // Store as 0–100 for easy state reading
      currentOpacity = Math.round(opacityPercentage * 100);
      const rgb = currentRgb.split("(")[1].split(")")[0];
      opacityHandle.style.backgroundColor = `rgba(${rgb}, ${opacityPercentage})`;
      colorInput.style.opacity = opacityPercentage;
      container.setAttribute(
        "value",
        currentOpacity != 100 ? `rgba(${rgb}, ${opacityPercentage})` : `rgb(${rgb})`,
      );
      const event = new CustomEvent<ColorPickerChangeEvent["detail"]>(
        "starwind-color-picker:change",
        {
          detail: {
            value: currentOpacity != 100 ? `rgba(${rgb}, ${opacityPercentage})` : `rgb(${rgb})`,
            selectId: container.id,
          },
          bubbles: true,
          composed: true,
          cancelable: true,
        },
      );
      container.dispatchEvent(event);
      updateTextInput();
    }

    // Update Opacity with Value (Directly)
    function updateOpacityValue(value: number) {
      currentOpacity = value * 100;
      const rgb = currentRgb.split("(")[1].split(")")[0];
      opacityHandle.style.backgroundColor = `rgba(${rgb}, ${value})`;
      const rect = opacitySlider.getBoundingClientRect();
      let x = rect.width * value;
      x = Math.max(0, Math.min(x, rect.width));
      opacityHandle.style.left = `${x}px`;
      colorInput.style.opacity = value;
      container.setAttribute(
        "value",
        currentOpacity != 100 ? `rgba(${rgb}, ${value})` : `rgb(${rgb})`,
      );
      const event = new CustomEvent<ColorPickerChangeEvent["detail"]>(
        "starwind-color-picker:change",
        {
          detail: {
            value: currentOpacity != 100 ? `rgba(${rgb}, ${value})` : `rgb(${rgb})`,
            selectId: container.id,
          },
          bubbles: true,
          composed: true,
          cancelable: true,
        },
      );
      container.dispatchEvent(event);
    }

    // Update Text Input Values After Selected Color Changes
    function updateTextInput() {
      const rgb = currentRgb.split("(")[1].split(")")[0];
      const [r, g, b] = rgb.split(",");
      if (currentColorFormat == "rgb") {
        textInputs[0].value = r;
        textInputs[1].value = g;
        textInputs[2].value = b;
        textInputs[3].value = Number(currentOpacity / 100).toFixed(2);
      } else if (currentColorFormat == "hex") {
        const hex = rgbToHex(r, g, b).slice(1);
        textInputs[0].value = hex.slice(0, 2) != "NaN" ? hex.slice(0, 2) : "00";
        textInputs[1].value = hex.slice(2, 4) != "NaN" ? hex.slice(2, 4) : "00";
        textInputs[2].value = hex.slice(4, 6) != "NaN" ? hex.slice(4, 6) : "00";
        textInputs[3].value = decimalOpacityToHex(currentOpacity) || "00";
      } else if (currentColorFormat == "hsb") {
        const [hsbR, hsbG, hsbB] = rgbToHsb(r, g, b);
        textInputs[0].value = hsbR;
        textInputs[1].value = hsbG;
        textInputs[2].value = hsbB;
        textInputs[3].value = Number(currentOpacity / 100).toFixed(2);
      } else if (currentColorFormat == "hsl") {
        const [hslR, hslG, hslB] = rgbToHsl(r, g, b);
        textInputs[0].value = hslR;
        textInputs[1].value = hslG;
        textInputs[2].value = hslB;
        textInputs[3].value = Number(currentOpacity / 100).toFixed(2);
      }
    }

    // Update UI After Selected Color Changes
    function updateUIFromRGB(r: number, g: number, b: number) {
      const [h, s, v] = rgbToHsb(r, g, b);

      const rect = satRect.getBoundingClientRect();

      // 2. Update Global State
      currentHue = h;

      // 3. Update Saturation Square background
      const pureColor = `hsl(${h}, 100%, 50%)`;
      satRect.style.backgroundColor = pureColor;
      hueHandle.style.backgroundColor = pureColor;

      // 4. Update Cursor Position (The Reverse Math)
      const x = (s / 100) * rect.width;
      const y = (1 - v / 100) * rect.height;

      cursor.style.left = `${x}px`;
      cursor.style.top = `${y}px`;

      // 5. Update Hue Slider Position
      const huePercent = h / 360;
      const trackWidth = hueSlider.offsetWidth;
      hueHandle.style.left = `${huePercent * trackWidth}px`;

      // 6. Finally, update the color input value
      setSelectedColor(r, g, b);
    }

    // Before Input Logic (Prevent invalid inputs)
    const isHexInputValid = (data: string, value: string) => {
      const regex = /[0-9a-fA-F]/;
      return value.length <= 1 && regex.test(data);
    };

    const isRgbInputValid = (data: string, value: string) => {
      const regex = /[0-9]/;
      return (
        value.length <= 2 &&
        regex.test(data) &&
        Number(`${value}${data}`) < 257 &&
        Number(`${value}${data}`) >= 0
      );
    };

    const isHsbHslValid = (data: string, value: string, index: number) => {
      const regex = /[0-9]/;
      return (
        value.length <= 2 &&
        regex.test(data) &&
        (index != 0 || Number(`${value}${data}`) <= 360) &&
        (index == 0 || Number(`${value}${data}`) <= 100) &&
        Number(`${value}${data}`) >= 0
      );
    };

    textInputs.forEach((input: HTMLInputElement, inputIndex: number) =>
      input.addEventListener("beforeinput", (e: InputEvent) => {
        const futureValue: number =
          e.target.value.slice(0, e.target.selectionStart) +
          (e.data || "") +
          e.target.value.slice(e.target.selectionEnd);
        if (e.data) {
          if (inputIndex == 3 && currentColorFormat != "hex") {
            const regex = /[0-9-.]/;
            if (!regex.test(e.data) || futureValue > 1 || futureValue < 0) {
              e.preventDefault();
            }
            return;
          }
          if (currentColorFormat == "hex" && !isHexInputValid(e.data, e.target.value)) {
            e.preventDefault();
          } else if (currentColorFormat == "rgb" && !isRgbInputValid(e.data, e.target.value)) {
            e.preventDefault();
          } else if (
            ["hsb", "hsl"].includes(currentColorFormat) &&
            !isHsbHslValid(e.data, e.target.value, inputIndex)
          ) {
            e.preventDefault();
          }
        }
      }),
    );

    // Input Change Logic (Update selector ui and value on input)
    textInputs.forEach((input: HTMLInputElement, inputIndex: number) =>
      input.addEventListener("change", (e: Event) => {
        if (inputIndex == 3) {
          const value =
            currentColorFormat == "hex" ? hexOpacityToDecimal(e.target.value) : e.target.value;
          updateOpacityValue(value);
          return;
        }
        let rgbValues: [number, number, number];
        if (currentColorFormat == "rgb") {
          const rgb = currentRgb.split("(")[1].split(")")[0];
          rgbValues = rgb.split(",");
          rgbValues[inputIndex] = e.target.value;
        } else if (currentColorFormat == "hex") {
          rgbValues = hexToRgb(
            `#${textInputs[0].value}${textInputs[1].value}${textInputs[2].value}`,
          );
        } else if (currentColorFormat == "hsb") {
          rgbValues = hsbToRgb(textInputs[0].value, textInputs[1].value, textInputs[2].value);
        } else if (currentColorFormat == "hsl") {
          rgbValues = hslToRgb(textInputs[0].value, textInputs[1].value, textInputs[2].value);
        } else {
          rgbValues = [0, 0, 0];
        }
        setSelectedColor(rgbValues[0], rgbValues[1], rgbValues[2]);
        updateUIFromRGB(rgbValues[0], rgbValues[1], rgbValues[2]);
      }),
    );

    // Translate Color Format Functions
    const rgbToHex = (r: number, g: number, b: number): string => {
      const [hexR, hexG, hexB] = [r, g, b].map((code) => {
        const hex = Math.round(code).toString(16);
        return hex.length === 1 ? "0" + hex : hex;
      });
      return `#${hexR}${hexG}${hexB}`;
    };

    function hexToRgb(hex: string): [number, number, number] {
      hex = hex.replace(/^#/, "");

      if (hex.length === 3) {
        hex = hex
          .split("")
          .map((char) => char + char)
          .join("");
      }

      const r = parseInt(hex.substring(0, 2), 16);
      const g = parseInt(hex.substring(2, 4), 16);
      const b = parseInt(hex.substring(4, 6), 16);

      return [r, g, b];
    }

    function decimalOpacityToHex(opacity: number): string {
      const percent = Math.max(0, Math.min(100, opacity)); // Ensure opacity is between 0 and 100
      const intValue = Math.round(percent * 2.55); // Map 0-100 to 0-255
      const hex = intValue.toString(16).padStart(2, "0");
      return hex;
    }
    function hexOpacityToDecimal(hexAlpha: string): number {
      const cleanHex = hexAlpha.replace("#", "");
      const alphaPart = cleanHex.length > 2 ? cleanHex.slice(-2) : cleanHex;

      const intValue = parseInt(alphaPart, 16);

      if (isNaN(intValue)) return 1; // Default to fully opaque if invalid

      return parseFloat((intValue / 255).toFixed(2));
    }

    function isValidRGB(color: string): boolean {
      const regex = /^rgba?\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*(?:,\s*([\d.]+)\s*)?\)$/i;
      const match = color.match(regex);

      if (!match) return false;

      const [r, g, b, a] = match.slice(1).map(Number);

      const rgbValid = [r, g, b].every((val) => !isNaN(val) && val >= 0 && val <= 255);

      const hasAlpha = match[4] !== undefined;
      const alphaValid = !hasAlpha || (a >= 0 && a <= 1);

      return rgbValid && alphaValid;
    }

    function rgbToHsl(r: number, g: number, b: number): [number, number, number] {
      r /= 255;
      g /= 255;
      b /= 255;

      const max = Math.max(r, g, b),
        min = Math.min(r, g, b);
      let h, s_hsl;
      const l = (max + min) / 2;

      const d = max - min;

      if (max === min) {
        h = s_hsl = 0;
      } else {
        switch (max) {
          case r:
            h = (g - b) / d + (g < b ? 6 : 0);
            break;
          case g:
            h = (b - r) / d + 2;
            break;
          case b:
            h = (r - g) / d + 4;
            break;
        }
        h /= 6;

        s_hsl = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      }

      return [Math.round(h * 360), Math.round(s_hsl * 100), Math.round(l * 100)];
    }

    function hslToRgb(h: number, s: number, l: number): [number, number, number] {
      const sNorm = s / 100;
      const lNorm = l / 100;

      const a = sNorm * Math.min(lNorm, 1 - lNorm);
      const k = (n: number) => (n + h / 30) % 12;
      const f = (n: number) => lNorm - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));

      return [Math.round(255 * f(0)), Math.round(255 * f(8)), Math.round(255 * f(4))];
    }

    function rgbToHsb(r: number, g: number, b: number): [number, number, number] {
      r /= 255;
      g /= 255;
      b /= 255;

      const max = Math.max(r, g, b),
        min = Math.min(r, g, b);
      let h, _;
      const __ = (max + min) / 2;
      let s_hsb;
      const v = max; // v is Brightness/Value

      const d = max - min;

      if (max === min) {
        h = s_hsb = 0;
      } else {
        switch (max) {
          case r:
            h = (g - b) / d + (g < b ? 6 : 0);
            break;
          case g:
            h = (b - r) / d + 2;
            break;
          case b:
            h = (r - g) / d + 4;
            break;
        }
        h /= 6;
        s_hsb = max === 0 ? 0 : d / max;
      }

      return [Math.round(h * 360), Math.round(s_hsb * 100), Math.round(v * 100)];
    }

    function hsbToRgb(h: number, s: number, b: number): [number, number, number] {
      const sNorm = s / 100;
      const bNorm = b / 100;

      const k = (n) => (n + h / 60) % 6;
      const f = (n) => bNorm * (1 - sNorm * Math.max(0, Math.min(k(n), 4 - k(n), 1)));

      return [Math.round(255 * f(5)), Math.round(255 * f(3)), Math.round(255 * f(1))];
    }

    function hsvToRgb(h: number, s: number, v: number): string {
      s /= 100;
      v /= 100;
      const k = (n) => (n + h / 60) % 6;
      const f = (n) => v * (1 - s * Math.max(0, Math.min(k(n), 4 - k(n), 1)));

      const r = Math.round(255 * f(5));
      const g = Math.round(255 * f(3));
      const b = Math.round(255 * f(1));

      return `rgb(${r}, ${g}, ${b})`;
    }
  }
</script>