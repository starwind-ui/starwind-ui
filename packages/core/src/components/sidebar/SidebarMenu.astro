---
import type { HTMLAttributes } from "astro/types";

import { sidebarMenu } from "./variants";

type Props = HTMLAttributes<"ul">;

const { class: className, ...rest } = Astro.props;
---

<ul
  class={sidebarMenu({ class: className })}
  data-sidebar="menu"
  {...rest}
  data-slot="sidebar-menu"
>
  <slot />
</ul>
