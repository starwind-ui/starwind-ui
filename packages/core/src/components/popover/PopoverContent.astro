---
import type { HTMLAttributes } from "astro/types";

import { popoverContent } from "./variants";

type Props = HTMLAttributes<"div"> & {
  /**
   * Side of the popover
   * @default bottom
   */
  side?: "top" | "bottom" | "left" | "right";
  /**
   * Alignment of the popover
   * @default center
   */
  align?: "start" | "center" | "end";
  /**
   * Offset distance in pixels
   * @default 4
   */
  sideOffset?: number;
  /**
   * Open and close animation duration in milliseconds
   * @default 150
   */
  animationDuration?: number;
  /**
   * Accessible name for the dialog when a PopoverTitle is not present.
   * If neither aria-label nor aria-labelledby is provided, a fallback label is applied.
   */
  "aria-label"?: string;
};

const {
  class: className,
  side = "bottom",
  align = "center",
  sideOffset = 4,
  animationDuration = 150,
  "aria-label": ariaLabel,
  "aria-labelledby": ariaLabelledBy,
  ...rest
} = Astro.props;
---

<div
  class={popoverContent({ side, align, class: className })}
  data-side={side}
  data-align={align}
  data-side-offset={sideOffset}
  data-state="closed"
  role="dialog"
  aria-label={ariaLabel ?? (ariaLabelledBy ? undefined : "Popover dialog")}
  aria-labelledby={ariaLabelledBy}
  tabindex="-1"
  style={{
    display: "none",
    animationDuration: `${animationDuration}ms`,
  }}
  {...rest}
  data-slot="popover-content"
>
  <slot />
</div>
