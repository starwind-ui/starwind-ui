{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@starwind-ui/runtime": ["../runtime/src/index.ts"],
      "@starwind-ui/runtime/theme": ["../runtime/src/theme/theme.ts"],
      "@starwind-ui/runtime/*": ["../runtime/src/components/*/index.ts"]
    },
    "types": ["node", "vue"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "scripts/**/*.mjs", "tsup.config.ts"],
  "exclude": ["dist", "node_modules"]
}
