---
import { Button } from "@/components/starwind-runtime/button";
import { button } from "@/components/starwind-runtime/button/variants";
import {
  Combobox,
  ComboboxContent,
  ComboboxEmpty,
  ComboboxInput,
  ComboboxItem,
  ComboboxLabel,
} from "@/components/starwind-runtime/combobox";
import {
  Dialog,
  DialogClose,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from "@/components/starwind-runtime/dialog";
import {
  Dropdown,
  DropdownContent,
  DropdownItem,
  DropdownLabel,
  DropdownTrigger,
} from "@/components/starwind-runtime/dropdown";
import { Input } from "@/components/starwind-runtime/input";
import { Label } from "@/components/starwind-runtime/label";
import {
  Popover,
  PopoverContent,
  PopoverDescription,
  PopoverHeader,
  PopoverTitle,
  PopoverTrigger,
} from "@/components/starwind-runtime/popover";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
} from "@/components/starwind-runtime/select";
---

<section class="mb-12">
  <h2 class="font-heading mb-4 text-2xl font-semibold">Dialog</h2>
  <div class="flex flex-wrap items-center gap-3">
    <Dialog id="runtime-dialog-default">
      <DialogTrigger class={button({ variant: "primary", size: "md" })}>
        Open dialog
      </DialogTrigger>
      <DialogContent>
        <DialogHeader>
          <DialogTitle>Runtime dialog</DialogTitle>
          <DialogDescription>
            This dialog uses the generated styled Astro wrapper and the native-dialog runtime
            controller.
          </DialogDescription>
        </DialogHeader>
        <div class="py-4">
          <label class="grid gap-2 text-sm font-medium">
            Example input
            <input
              class="border-input bg-background focus-visible:ring-outline/50 h-10 rounded-md border px-3 outline-none focus-visible:ring-3"
              value="Focus trap target"
            />
          </label>
        </div>
        <DialogFooter>
          <DialogClose class={button({ variant: "outline", size: "sm" })}> Close </DialogClose>
        </DialogFooter>
      </DialogContent>
    </Dialog>

    <DialogTrigger
      targetId="runtime-dialog-edit-profile"
      class={button({ variant: "outline", size: "md" })}
    >
      Edit profile
    </DialogTrigger>

    <Dialog id="runtime-dialog-edit-profile">
      <DialogTrigger asChild>
        <Button id="runtime-dialog-edit-profile-trigger" variant="secondary">
          Open edit form
        </Button>
      </DialogTrigger>
      <DialogContent>
        <DialogHeader>
          <DialogTitle>Edit profile</DialogTitle>
          <DialogDescription>Update the profile details used in the runtime demo.</DialogDescription
          >
        </DialogHeader>
        <div class="grid gap-4 py-4">
          <div class="grid gap-2">
            <Label for="runtime-dialog-name" size="sm">Name</Label>
            <Input id="runtime-dialog-name" defaultValue="Ada Lovelace" />
          </div>
          <div class="grid gap-2">
            <Label for="runtime-dialog-username" size="sm">Username</Label>
            <Input id="runtime-dialog-username" defaultValue="@ada" />
          </div>
        </div>
        <DialogFooter class="gap-2">
          <DialogClose asChild>
            <Button variant="outline" size="sm">Cancel</Button>
          </DialogClose>
          <DialogClose asChild>
            <Button variant="primary" size="sm">Save changes</Button>
          </DialogClose>
        </DialogFooter>
      </DialogContent>
    </Dialog>

    <Dialog id="runtime-nested-dialog-parent">
      <DialogTrigger asChild>
        <Button id="runtime-nested-dialog-parent-trigger" variant="outline">
          Open nested parent
        </Button>
      </DialogTrigger>
      <DialogContent>
        <DialogHeader>
          <DialogTitle>Runtime nested parent</DialogTitle>
          <DialogDescription>
            Mirrors the old Starwind nested dialog demo with deeper dialog levels.
          </DialogDescription>
        </DialogHeader>
        <DialogFooter class="mt-4 flex-col gap-2 sm:flex-row">
          <Dialog id="runtime-nested-dialog-level-one">
            <DialogTrigger asChild>
              <Button id="runtime-nested-dialog-level-one-trigger" variant="secondary" size="sm">
                Open nested level 1
              </Button>
            </DialogTrigger>
            <DialogContent>
              <DialogHeader>
                <DialogTitle>Runtime nested level 1</DialogTitle>
                <DialogDescription>
                  This level can open another dialog without closing its parent.
                </DialogDescription>
              </DialogHeader>
              <DialogFooter class="mt-4 flex-col gap-2 sm:flex-row">
                <Dialog id="runtime-nested-dialog-level-two">
                  <DialogTrigger asChild>
                    <Button
                      id="runtime-nested-dialog-level-two-trigger"
                      variant="primary"
                      size="sm"
                    >
                      Open nested level 2
                    </Button>
                  </DialogTrigger>
                  <DialogContent>
                    <DialogHeader>
                      <DialogTitle>Runtime nested level 2</DialogTitle>
                      <DialogDescription>
                        Closing this second nested level should let the older dialogs resize
                        immediately while this level exits.
                      </DialogDescription>
                    </DialogHeader>
                    <DialogFooter class="mt-4">
                      <DialogClose asChild>
                        <Button
                          id="runtime-nested-dialog-level-two-close"
                          variant="outline"
                          size="sm"
                        >
                          Close level 2
                        </Button>
                      </DialogClose>
                    </DialogFooter>
                  </DialogContent>
                </Dialog>
                <DialogClose asChild>
                  <Button id="runtime-nested-dialog-level-one-close" variant="outline" size="sm">
                    Close level 1
                  </Button>
                </DialogClose>
              </DialogFooter>
            </DialogContent>
          </Dialog>
          <DialogClose asChild>
            <Button id="runtime-nested-dialog-parent-close" variant="outline" size="sm">
              Close parent
            </Button>
          </DialogClose>
        </DialogFooter>
      </DialogContent>
    </Dialog>

    <Dialog id="runtime-dialog-overlay-lab">
      <DialogTrigger asChild>
        <Button id="runtime-dialog-overlay-lab-trigger" variant="outline">
          Open overlay lab
        </Button>
      </DialogTrigger>
      <DialogContent
        id="runtime-dialog-overlay-lab-content"
        class="max-h-[calc(100vh-4rem)] max-w-2xl overflow-y-auto"
      >
        <DialogHeader>
          <DialogTitle>Overlays inside a dialog</DialogTitle>
          <DialogDescription>
            Open each control to verify that its floating content remains interactive without
            closing the parent dialog.
          </DialogDescription>
        </DialogHeader>

        <div class="grid gap-4 py-4 sm:grid-cols-2">
          <div class="min-w-0 space-y-3 rounded-lg border p-4">
            <h3 class="font-heading text-sm font-semibold">Popover</h3>
            <Popover id="runtime-dialog-popover">
              <PopoverTrigger
                id="runtime-dialog-popover-trigger"
                class={button({ variant: "outline", size: "sm" })}
              >
                Open popover
              </PopoverTrigger>
              <PopoverContent id="runtime-dialog-popover-content" side="bottom" align="start">
                <PopoverHeader>
                  <PopoverTitle>Dialog popover</PopoverTitle>
                  <PopoverDescription>
                    This popup should stay above and inside the modal dialog.
                  </PopoverDescription>
                </PopoverHeader>
                <Dialog id="runtime-dialog-overlay-nested">
                  <DialogTrigger asChild>
                    <Button
                      id="runtime-dialog-overlay-nested-trigger"
                      variant="secondary"
                      size="sm"
                    >
                      Open nested overlay dialog
                    </Button>
                  </DialogTrigger>
                  <DialogContent
                    id="runtime-dialog-overlay-nested-content"
                    class="max-h-64 max-w-sm overflow-hidden"
                  >
                    <DialogHeader>
                      <DialogTitle>Nested overlay dialog</DialogTitle>
                      <DialogDescription>
                        Its popover should escape this deliberately clipped dialog surface.
                      </DialogDescription>
                    </DialogHeader>
                    <div
                      data-runtime-dialog-overlay-clip
                      class="h-16 overflow-hidden rounded border p-2"
                    >
                      <Popover id="runtime-dialog-overlay-nested-popover">
                        <PopoverTrigger
                          id="runtime-dialog-overlay-nested-popover-trigger"
                          class={button({ variant: "outline", size: "sm" })}
                        >
                          Open nested popover
                        </PopoverTrigger>
                        <PopoverContent
                          id="runtime-dialog-overlay-nested-popover-content"
                          class="w-80"
                          side="bottom"
                          align="start"
                        >
                          <PopoverTitle>Nested dialog popover</PopoverTitle>
                          <PopoverDescription>
                            This content remains interactive outside the clipped region.
                          </PopoverDescription>
                          <Button id="runtime-dialog-overlay-nested-popover-action" size="sm">
                            Confirm nested action
                          </Button>
                        </PopoverContent>
                      </Popover>
                    </div>
                    <DialogFooter>
                      <DialogClose asChild>
                        <Button
                          id="runtime-dialog-overlay-nested-close"
                          variant="outline"
                          size="sm"
                        >
                          Close nested dialog
                        </Button>
                      </DialogClose>
                    </DialogFooter>
                  </DialogContent>
                </Dialog>
                <Button id="runtime-dialog-popover-action" variant="ghost" size="sm">
                  Confirm parent action
                </Button>
              </PopoverContent>
            </Popover>
          </div>

          <div class="min-w-0 space-y-3 rounded-lg border p-4">
            <h3 class="font-heading text-sm font-semibold">Select</h3>
            <Select
              id="runtime-dialog-select"
              defaultValue="system"
              name="runtimeDialogTheme"
              class="w-full"
            >
              <SelectTrigger
                id="runtime-dialog-select-trigger"
                class="w-full"
                placeholder="Choose a theme"
              />
              <SelectContent id="runtime-dialog-select-content" alignItemWithTrigger={false}>
                <SelectItem id="runtime-dialog-select-light" value="light"> Light </SelectItem>
                <SelectItem id="runtime-dialog-select-system" value="system"> System </SelectItem>
                <SelectItem id="runtime-dialog-select-dark" value="dark"> Dark </SelectItem>
              </SelectContent>
            </Select>
          </div>

          <div class="min-w-0 space-y-3 rounded-lg border p-4">
            <h3 class="font-heading text-sm font-semibold">Combobox</h3>
            <Combobox id="runtime-dialog-combobox" name="runtimeDialogFruit">
              <ComboboxLabel>Fruit</ComboboxLabel>
              <ComboboxInput id="runtime-dialog-combobox-input" placeholder="Search fruit" />
              <ComboboxContent id="runtime-dialog-combobox-content">
                <ComboboxEmpty>No fruit found.</ComboboxEmpty>
                <ComboboxItem id="runtime-dialog-combobox-apple" value="apple">
                  Apple
                </ComboboxItem>
                <ComboboxItem id="runtime-dialog-combobox-apricot" value="apricot">
                  Apricot
                </ComboboxItem>
                <ComboboxItem id="runtime-dialog-combobox-banana" value="banana">
                  Banana
                </ComboboxItem>
              </ComboboxContent>
            </Combobox>
          </div>

          <div class="min-w-0 space-y-3 rounded-lg border p-4">
            <h3 class="font-heading text-sm font-semibold">Dropdown</h3>
            <Dropdown id="runtime-dialog-dropdown">
              <DropdownTrigger
                id="runtime-dialog-dropdown-trigger"
                class={button({ variant: "outline", size: "sm" })}
              >
                Open menu
              </DropdownTrigger>
              <DropdownContent id="runtime-dialog-dropdown-content" side="bottom" align="start">
                <DropdownLabel>Project actions</DropdownLabel>
                <DropdownItem id="runtime-dialog-dropdown-duplicate"> Duplicate </DropdownItem>
                <DropdownItem id="runtime-dialog-dropdown-rename"> Rename </DropdownItem>
                <DropdownItem id="runtime-dialog-dropdown-archive"> Archive </DropdownItem>
              </DropdownContent>
            </Dropdown>
          </div>
        </div>

        <DialogFooter>
          <DialogClose asChild>
            <Button id="runtime-dialog-overlay-lab-close" variant="outline" size="sm">
              Close lab
            </Button>
          </DialogClose>
        </DialogFooter>
      </DialogContent>
    </Dialog>
  </div>
</section>
