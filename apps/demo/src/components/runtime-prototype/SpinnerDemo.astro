---
import { Spinner } from "@/components/starwind-runtime/spinner";
---

<section class="mb-12">
  <h2 class="font-heading mb-4 text-2xl font-semibold">Spinner</h2>
  <div class="flex flex-wrap items-start gap-6">
    <div>
      <p class="text-muted-foreground mb-2 text-sm">Default</p>
      <Spinner />
    </div>
    <div>
      <p class="text-muted-foreground mb-2 text-sm">Large</p>
      <Spinner class="size-8" />
    </div>
    <div>
      <p class="text-muted-foreground mb-2 text-sm">Custom Color</p>
      <Spinner class="text-primary size-6" />
    </div>
  </div>
</section>
