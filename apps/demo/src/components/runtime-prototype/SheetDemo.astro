---
import Copy from "@tabler/icons/outline/copy.svg";

import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from "@/components/starwind-runtime/accordion";
import { Button } from "@/components/starwind-runtime/button";
import { button } from "@/components/starwind-runtime/button/variants";
import {
  Collapsible,
  CollapsibleContent,
  CollapsibleTrigger,
} from "@/components/starwind-runtime/collapsible";
import {
  Dropdown,
  DropdownCheckboxItem,
  DropdownCheckboxItemIndicator,
  DropdownContent,
  DropdownGroup,
  DropdownItem,
  DropdownLabel,
  DropdownRadioGroup,
  DropdownRadioItem,
  DropdownRadioItemIndicator,
  DropdownSeparator,
  DropdownShortcut,
  DropdownSub,
  DropdownSubContent,
  DropdownSubTrigger,
  DropdownTrigger,
} from "@/components/starwind-runtime/dropdown";
import { Input } from "@/components/starwind-runtime/input";
import { Label } from "@/components/starwind-runtime/label";
import {
  Popover,
  PopoverContent,
  PopoverDescription,
  PopoverHeader,
  PopoverTitle,
  PopoverTrigger,
} from "@/components/starwind-runtime/popover";
import {
  Sheet,
  SheetClose,
  SheetContent,
  SheetDescription,
  SheetFooter,
  SheetHeader,
  SheetTitle,
  SheetTrigger,
} from "@/components/starwind-runtime/sheet";
---

<section class="mb-12">
  <h2 class="font-heading mb-4 text-2xl font-semibold">Sheet</h2>
  <Sheet id="runtime-sheet-default">
    <SheetTrigger class={button({ variant: "outline", size: "md" })}> Open sheet </SheetTrigger>
    <SheetContent class="runtime-sheet-custom" side="right">
      <SheetHeader>
        <SheetTitle>Runtime sheet</SheetTitle>
        <SheetDescription>
          Sheet uses Base UI-style Drawer primitive parts and Starwind Sheet styling.
        </SheetDescription>
      </SheetHeader>
      <div class="text-muted-foreground px-4 py-2 text-sm">
        Outside interaction closes this sheet by default, matching the Drawer primitive's
        dismissible behavior.
      </div>
    </SheetContent>
  </Sheet>

  <div id="runtime-sheet-directions" class="mt-4 flex flex-wrap gap-3">
    <Sheet id="runtime-sheet-side-top">
      <SheetTrigger asChild>
        <Button id="runtime-sheet-side-top-trigger" variant="outline">Open top sheet</Button>
      </SheetTrigger>
      <SheetContent side="top">
        <SheetHeader>
          <SheetTitle>Top sheet direction</SheetTitle>
          <SheetDescription>This sheet opens from the top of the screen.</SheetDescription>
        </SheetHeader>
        <div class="grid flex-1 auto-rows-min gap-6 px-4">
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-top-name">Name</Label>
            <Input id="runtime-sheet-side-top-name" value="Pedro Duarte" />
          </div>
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-top-username">Username</Label>
            <Input id="runtime-sheet-side-top-username" value="@peduarte" />
          </div>
        </div>
        <SheetFooter>
          <Button variant="default">Save changes</Button>
          <SheetClose asChild>
            <Button id="runtime-sheet-side-top-close" variant="outline">Close top sheet</Button>
          </SheetClose>
        </SheetFooter>
      </SheetContent>
    </Sheet>

    <Sheet id="runtime-sheet-side-right">
      <SheetTrigger asChild>
        <Button id="runtime-sheet-side-right-trigger" variant="outline"> Open right sheet </Button>
      </SheetTrigger>
      <SheetContent side="right">
        <SheetHeader>
          <SheetTitle>Right sheet direction</SheetTitle>
          <SheetDescription>This sheet opens from the right side of the screen.</SheetDescription>
        </SheetHeader>
        <div class="grid flex-1 auto-rows-min gap-6 px-4">
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-right-name">Name</Label>
            <Input id="runtime-sheet-side-right-name" value="Pedro Duarte" />
          </div>
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-right-username">Username</Label>
            <Input id="runtime-sheet-side-right-username" value="@peduarte" />
          </div>
        </div>
        <SheetFooter>
          <Button variant="default">Save changes</Button>
          <SheetClose asChild>
            <Button id="runtime-sheet-side-right-close" variant="outline">
              Close right sheet
            </Button>
          </SheetClose>
        </SheetFooter>
      </SheetContent>
    </Sheet>

    <Sheet id="runtime-sheet-side-bottom">
      <SheetTrigger asChild>
        <Button id="runtime-sheet-side-bottom-trigger" variant="outline">
          Open bottom sheet
        </Button>
      </SheetTrigger>
      <SheetContent side="bottom">
        <SheetHeader>
          <SheetTitle>Bottom sheet direction</SheetTitle>
          <SheetDescription>This sheet opens from the bottom of the screen.</SheetDescription>
        </SheetHeader>
        <div class="grid flex-1 auto-rows-min gap-6 px-4">
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-bottom-name">Name</Label>
            <Input id="runtime-sheet-side-bottom-name" value="Pedro Duarte" />
          </div>
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-bottom-username">Username</Label>
            <Input id="runtime-sheet-side-bottom-username" value="@peduarte" />
          </div>
        </div>
        <SheetFooter>
          <Button variant="default">Save changes</Button>
          <SheetClose asChild>
            <Button id="runtime-sheet-side-bottom-close" variant="outline">
              Close bottom sheet
            </Button>
          </SheetClose>
        </SheetFooter>
      </SheetContent>
    </Sheet>

    <Sheet id="runtime-sheet-side-left">
      <SheetTrigger asChild>
        <Button id="runtime-sheet-side-left-trigger" variant="outline">Open left sheet</Button>
      </SheetTrigger>
      <SheetContent side="left">
        <SheetHeader>
          <SheetTitle>Left sheet direction</SheetTitle>
          <SheetDescription>This sheet opens from the left side of the screen.</SheetDescription>
        </SheetHeader>
        <div class="grid flex-1 auto-rows-min gap-6 px-4">
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-left-name">Name</Label>
            <Input id="runtime-sheet-side-left-name" value="Pedro Duarte" />
          </div>
          <div class="grid gap-3">
            <Label for="runtime-sheet-side-left-username">Username</Label>
            <Input id="runtime-sheet-side-left-username" value="@peduarte" />
          </div>
        </div>
        <SheetFooter>
          <Button variant="default">Save changes</Button>
          <SheetClose asChild>
            <Button id="runtime-sheet-side-left-close" variant="outline"> Close left sheet </Button>
          </SheetClose>
        </SheetFooter>
      </SheetContent>
    </Sheet>
  </div>

  <Sheet id="runtime-sheet-dropdown-sheet">
    <SheetTrigger asChild>
      <Button id="runtime-sheet-dropdown-sheet-trigger" variant="secondary">
        Open sheet menu
      </Button>
    </SheetTrigger>
    <SheetContent side="right">
      <SheetHeader>
        <SheetTitle>Sheet dropdown portal</SheetTitle>
        <SheetDescription>
          Dropdown content opened from inside this sheet should use the sheet floating root.
        </SheetDescription>
      </SheetHeader>
      <div class="grid flex-1 auto-rows-min gap-4 overflow-hidden px-4 py-2">
        <label class="grid gap-2 text-sm font-medium">
          Project
          <input
            id="runtime-sheet-dropdown-input"
            class="border-input bg-background focus-visible:ring-outline/50 h-10 rounded-md border px-3 outline-none focus-visible:ring-3"
            value="Portal QA"
          />
        </label>
        <div class="grid gap-2">
          <span class="text-sm font-medium">Actions menu</span>
          <Dropdown id="runtime-sheet-dropdown">
            <DropdownTrigger asChild>
              <Button id="runtime-sheet-dropdown-trigger" variant="outline" size="sm">
                Open sheet dropdown
              </Button>
            </DropdownTrigger>
            <DropdownContent id="runtime-sheet-dropdown-content" side="left" align="start">
              <DropdownLabel>Sheet actions</DropdownLabel>
              <DropdownItem id="runtime-sheet-dropdown-rename"> Rename project </DropdownItem>
              <DropdownItem id="runtime-sheet-dropdown-duplicate"> Duplicate </DropdownItem>
              <DropdownSub>
                <DropdownSubTrigger id="runtime-sheet-dropdown-sub-trigger">
                  Share
                </DropdownSubTrigger>
                <DropdownSubContent id="runtime-sheet-dropdown-sub-content">
                  <DropdownItem id="runtime-sheet-dropdown-email"> Email invite </DropdownItem>
                  <DropdownItem id="runtime-sheet-dropdown-copy"> Copy link </DropdownItem>
                </DropdownSubContent>
              </DropdownSub>
              <DropdownSeparator />
              <DropdownItem id="runtime-sheet-dropdown-archive"> Archive </DropdownItem>
            </DropdownContent>
          </Dropdown>
        </div>
      </div>
      <SheetFooter>
        <SheetClose asChild>
          <Button id="runtime-sheet-dropdown-close" variant="outline" size="sm">
            Close sheet menu
          </Button>
        </SheetClose>
      </SheetFooter>
    </SheetContent>
  </Sheet>

  <Sheet id="runtime-sheet-popover">
    <SheetTrigger asChild>
      <Button id="runtime-sheet-popover-trigger" variant="secondary"> Open sheet popover </Button>
    </SheetTrigger>
    <SheetContent side="left">
      <SheetHeader>
        <SheetTitle>Sheet popover portal</SheetTitle>
        <SheetDescription>
          Popover content opened from inside this sheet should use the sheet floating root.
        </SheetDescription>
      </SheetHeader>
      <div class="grid flex-1 auto-rows-min gap-4 px-4 py-2">
        <label class="grid gap-2 text-sm font-medium">
          Workspace
          <input
            id="runtime-sheet-popover-input"
            class="border-input bg-background focus-visible:ring-outline/50 h-10 rounded-md border px-3 outline-none focus-visible:ring-3"
            value="Portal QA"
          />
        </label>
        <div class="grid gap-2">
          <span class="text-sm font-medium">Details popover</span>
          <Popover id="runtime-sheet-popover-details">
            <PopoverTrigger asChild>
              <Button id="runtime-sheet-popover-details-trigger" variant="outline" size="sm">
                Open sheet popover details
              </Button>
            </PopoverTrigger>
            <PopoverContent
              id="runtime-sheet-popover-details-content"
              class="w-72"
              side="right"
              align="start"
            >
              <PopoverHeader>
                <PopoverTitle>Sheet popover</PopoverTitle>
                <PopoverDescription>
                  This popover should render above the sheet without being clipped.
                </PopoverDescription>
              </PopoverHeader>
              <div class="mt-3">
                <Popover id="runtime-sheet-popover-nested">
                  <PopoverTrigger asChild>
                    <Button id="runtime-sheet-popover-nested-trigger" variant="outline" size="sm">
                      Open nested sheet popover
                    </Button>
                  </PopoverTrigger>
                  <PopoverContent
                    id="runtime-sheet-popover-nested-content"
                    class="w-64"
                    side="right"
                    align="start"
                  >
                    <PopoverHeader>
                      <PopoverTitle>Nested sheet popover</PopoverTitle>
                      <PopoverDescription>
                        Nested content should share the sheet floating root.
                      </PopoverDescription>
                    </PopoverHeader>
                  </PopoverContent>
                </Popover>
              </div>
            </PopoverContent>
          </Popover>
        </div>
      </div>
      <SheetFooter>
        <SheetClose asChild>
          <Button id="runtime-sheet-popover-close" variant="outline" size="sm">
            Close sheet popover
          </Button>
        </SheetClose>
      </SheetFooter>
    </SheetContent>
  </Sheet>

  <Sheet id="runtime-sheet-accordion">
    <SheetTrigger asChild>
      <Button id="runtime-sheet-accordion-trigger" variant="secondary">
        Open sheet accordion menu
      </Button>
    </SheetTrigger>
    <SheetContent side="right" class="flex-col">
      <SheetHeader>
        <SheetTitle>Sheet accordion navigation</SheetTitle>
        <SheetDescription>Navigate through sections while the sheet remains open.</SheetDescription>
      </SheetHeader>
      <nav class="flex flex-1 flex-col gap-2 px-4" aria-label="Sheet accordion navigation">
        <a
          id="runtime-sheet-accordion-home-link"
          href="#"
          class="hover:bg-muted rounded-md px-3 py-2 text-sm font-medium transition-colors"
        >
          Home
        </a>
        <a
          id="runtime-sheet-accordion-about-link"
          href="#"
          class="hover:bg-muted rounded-md px-3 py-2 text-sm font-medium transition-colors"
        >
          About
        </a>
        <Accordion
          id="runtime-sheet-accordion-menu"
          type="single"
          collapsible
          class="w-full space-y-2"
        >
          <AccordionItem value="products" class="border-none">
            <AccordionTrigger
              id="runtime-sheet-accordion-products-trigger"
              class="hover:bg-muted rounded-md px-3 py-2 text-sm font-medium hover:no-underline"
            >
              Products
            </AccordionTrigger>
            <AccordionContent id="runtime-sheet-accordion-products-content">
              <div class="flex flex-col gap-1 pl-4">
                <a
                  id="runtime-sheet-accordion-all-products-link"
                  href="#"
                  class="hover:bg-muted rounded-md px-3 py-2 text-sm transition-colors"
                >
                  All Products
                </a>
                <a
                  id="runtime-sheet-accordion-featured-link"
                  href="#"
                  class="hover:bg-muted rounded-md px-3 py-2 text-sm transition-colors"
                >
                  Featured
                </a>
                <a
                  id="runtime-sheet-accordion-new-arrivals-link"
                  href="#"
                  class="hover:bg-muted rounded-md px-3 py-2 text-sm transition-colors"
                >
                  New Arrivals
                </a>
              </div>
            </AccordionContent>
          </AccordionItem>
          <AccordionItem value="services" class="border-none">
            <AccordionTrigger
              id="runtime-sheet-accordion-services-trigger"
              class="hover:bg-muted rounded-md px-3 py-2 text-sm font-medium hover:no-underline"
            >
              Services
            </AccordionTrigger>
            <AccordionContent id="runtime-sheet-accordion-services-content">
              <div class="flex flex-col gap-1 pl-4">
                <a
                  id="runtime-sheet-accordion-consulting-link"
                  href="#"
                  class="hover:bg-muted rounded-md px-3 py-2 text-sm transition-colors"
                >
                  Consulting
                </a>
                <a
                  id="runtime-sheet-accordion-development-link"
                  href="#"
                  class="hover:bg-muted rounded-md px-3 py-2 text-sm transition-colors"
                >
                  Development
                </a>
                <a
                  id="runtime-sheet-accordion-support-link"
                  href="#"
                  class="hover:bg-muted rounded-md px-3 py-2 text-sm transition-colors"
                >
                  Support
                </a>
              </div>
            </AccordionContent>
          </AccordionItem>
        </Accordion>
        <a
          id="runtime-sheet-accordion-blog-link"
          href="#"
          class="hover:bg-muted rounded-md px-3 py-2 text-sm font-medium transition-colors"
        >
          Blog
        </a>
        <a
          id="runtime-sheet-accordion-contact-link"
          href="#"
          class="hover:bg-muted rounded-md px-3 py-2 text-sm font-medium transition-colors"
        >
          Contact
        </a>
      </nav>
      <SheetFooter class="mt-auto">
        <SheetClose asChild>
          <Button id="runtime-sheet-accordion-close" variant="outline" class="w-full">
            Close Menu
          </Button>
        </SheetClose>
      </SheetFooter>
    </SheetContent>
  </Sheet>

  <Sheet id="runtime-sheet-accordion-faq">
    <SheetTrigger asChild>
      <Button id="runtime-sheet-accordion-faq-trigger" variant="secondary"> Open sheet FAQ </Button>
    </SheetTrigger>
    <SheetContent side="left" class="flex-col">
      <SheetHeader>
        <SheetTitle>Sheet FAQ accordion</SheetTitle>
        <SheetDescription>
          The default-open item can be closed without leaving the sheet.
        </SheetDescription>
      </SheetHeader>
      <div class="px-4">
        <Accordion
          id="runtime-sheet-accordion-faq-menu"
          type="single"
          defaultValue="availability"
          collapsible
          class="w-full"
        >
          <AccordionItem value="availability">
            <AccordionTrigger id="runtime-sheet-accordion-faq-availability-trigger">
              Availability
            </AccordionTrigger>
            <AccordionContent id="runtime-sheet-accordion-faq-availability-content">
              Runtime sheets keep focus trapped while accordion sections open and close.
            </AccordionContent>
          </AccordionItem>
          <AccordionItem value="handoff">
            <AccordionTrigger id="runtime-sheet-accordion-faq-handoff-trigger">
              Handoff
            </AccordionTrigger>
            <AccordionContent id="runtime-sheet-accordion-faq-handoff-content">
              Collapsible single accordions work inside the same native dialog surface.
            </AccordionContent>
          </AccordionItem>
        </Accordion>
      </div>
      <SheetFooter class="mt-auto">
        <SheetClose asChild>
          <Button id="runtime-sheet-accordion-faq-close" variant="outline" class="w-full">
            Close FAQ
          </Button>
        </SheetClose>
      </SheetFooter>
    </SheetContent>
  </Sheet>
</section>
