---
import Flame from "@tabler/icons/outline/flame.svg";
import InfoCircle from "@tabler/icons/outline/info-circle.svg";

import { Alert, AlertDescription, AlertTitle } from "@/components/starwind-runtime/alert";
---

<section class="mb-12">
  <h2 class="font-heading mb-4 text-2xl font-semibold">Alert</h2>
  <div class="grid gap-4">
    <Alert id="runtime-alert-default" class="runtime-alert-custom">
      <AlertTitle>Heads up!</AlertTitle>
      <AlertDescription>Generated alert anatomy with the default status role.</AlertDescription>
    </Alert>
    <Alert id="runtime-alert-warning" variant="warning">
      <AlertTitle><InfoCircle class="size-6" /> Check this first</AlertTitle>
      <AlertDescription>Warning alerts infer the alert role.</AlertDescription>
    </Alert>
    <Alert id="runtime-alert-error-override" variant="error" role="status">
      <AlertTitle><Flame class="size-6" /> Non-interruptive error</AlertTitle>
      <AlertDescription>An explicit role still wins over variant inference.</AlertDescription>
    </Alert>
  </div>
</section>
