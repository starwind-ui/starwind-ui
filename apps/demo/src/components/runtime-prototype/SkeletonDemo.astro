---
import { Skeleton } from "@/components/starwind-runtime/skeleton";
---

<section class="mb-12" id="runtime-skeleton-demo">
  <h2 class="font-heading mb-4 text-2xl font-semibold">Skeleton</h2>
  <div class="flex max-w-sm items-center gap-3">
    <Skeleton class="runtime-skeleton-custom size-12 rounded-full" aria-hidden="true" />
    <div class="flex-1 space-y-2">
      <Skeleton class="h-4 w-28" aria-hidden="true" />
      <Skeleton class="h-3 w-40" aria-hidden="true" />
    </div>
  </div>
</section>
