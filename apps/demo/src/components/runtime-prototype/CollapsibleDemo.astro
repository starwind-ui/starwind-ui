---
import IconSelector from "@tabler/icons/outline/selector.svg";

import { Button } from "@/components/starwind-runtime/button";
import { button } from "@/components/starwind-runtime/button/variants";
import {
  Collapsible,
  CollapsibleContent,
  CollapsibleTrigger,
} from "@/components/starwind-runtime/collapsible";
---

<section class="mb-12">
  <h2 class="font-heading mb-4 text-2xl font-semibold">Collapsible</h2>
  <div class="grid gap-4 md:grid-cols-2">
    <Collapsible class="w-full max-w-[350px] space-y-2" defaultOpen>
      <div class="flex items-center justify-between space-x-4 px-4">
        <h4 class="text-sm font-semibold">@starwind-ui starred 3 repositories</h4>
        <CollapsibleTrigger asChild>
          <Button variant="ghost" size="icon-sm">
            <IconSelector class="size-4" />
            <span class="sr-only">Runtime notes</span>
          </Button>
        </CollapsibleTrigger>
      </div>
      <div class="rounded-md border px-4 py-2 font-mono text-sm">astro</div>
      <CollapsibleContent class="space-y-2">
        <div class="rounded-md border px-4 py-2 font-mono text-sm">tailwindcss</div>
        <div class="rounded-md border px-4 py-2 font-mono text-sm">starwind-ui</div>
      </CollapsibleContent>
    </Collapsible>

    <Collapsible class="max-w-xl rounded-md border p-4">
      <CollapsibleTrigger asChild class={button({ variant: "secondary", size: "sm" })}>
        <button id="runtime-collapsible-as-child-trigger" type="button"> As child notes </button>
      </CollapsibleTrigger>
      <CollapsibleContent
        id="runtime-collapsible-as-child-content"
        class="text-muted-foreground mt-3 text-sm"
      >
        This trigger is supplied as a child element while the runtime owns the state.
      </CollapsibleContent>
    </Collapsible>
  </div>
</section>
