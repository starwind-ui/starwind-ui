---
import type { HTMLAttributes } from "astro/types";

import "./styles.css";
import ScrollAreaPrimitive from "@starwind-ui/astro/scroll-area";
import {
  scrollArea,
  scrollAreaContent,
  scrollAreaCorner,
  scrollAreaScrollbar,
  scrollAreaThumb,
  scrollAreaViewport,
} from "./variants";

type Props = HTMLAttributes<"div"> & {
  overflowEdgeThreshold?: number;
  viewportClass?: string;
};

const { overflowEdgeThreshold, viewportClass, class: className, ...rest } = Astro.props;
---

<ScrollAreaPrimitive.Root
  class={scrollArea({ class: className })}
  overflowEdgeThreshold={overflowEdgeThreshold}
  {...rest}
  data-slot="scroll-area"
>
  <ScrollAreaPrimitive.Viewport
    class={scrollAreaViewport({ class: viewportClass })}
    data-slot="scroll-area-viewport"
  >
    <ScrollAreaPrimitive.Content class={scrollAreaContent()} data-slot="scroll-area-content">
      <slot />
    </ScrollAreaPrimitive.Content>
  </ScrollAreaPrimitive.Viewport>

  <slot name="scrollbar">
    <ScrollAreaPrimitive.Scrollbar class={scrollAreaScrollbar()} data-slot="scroll-area-scrollbar">
      <ScrollAreaPrimitive.Thumb class={scrollAreaThumb()} data-slot="scroll-area-thumb" />
    </ScrollAreaPrimitive.Scrollbar>
  </slot>

  <ScrollAreaPrimitive.Corner class={scrollAreaCorner()} data-slot="scroll-area-corner" />
</ScrollAreaPrimitive.Root>
