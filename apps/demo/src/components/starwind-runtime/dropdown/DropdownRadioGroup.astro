---
import MenuPrimitive from "@starwind-ui/astro/menu";
import type { HTMLAttributes } from "astro/types";
import { dropdownRadioGroup } from "./variants";

type Props = HTMLAttributes<"div"> & {
  value?: string;
  defaultValue?: string;
};

const { class: className, value, defaultValue, ...rest } = Astro.props;
---

<MenuPrimitive.RadioGroup
  class={dropdownRadioGroup({ class: className })}
  value={value}
  defaultValue={defaultValue}
  {...rest}
  data-slot="dropdown-radio-group"
>
  <slot />
</MenuPrimitive.RadioGroup>
