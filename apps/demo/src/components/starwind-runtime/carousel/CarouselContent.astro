---
import CarouselPrimitive from "@starwind-ui/astro/carousel";
import type { HTMLAttributes } from "astro/types";
import { carouselContainer, carouselContent } from "./variants";

type Props = HTMLAttributes<"div">;

const { class: className, ...rest } = Astro.props;
---

<CarouselPrimitive.Viewport class={carouselContent()} {...rest} data-slot="carousel-content">
  <CarouselPrimitive.Container
    class={carouselContainer({ class: className })}
    data-slot="carousel-container"
  >
    <slot />
  </CarouselPrimitive.Container>
</CarouselPrimitive.Viewport>
