---
import SheetPrimitive from "@starwind-ui/astro/drawer";
import type { HTMLAttributes } from "astro/types";
import { sheetTitle } from "./variants";

type Props = HTMLAttributes<"h2">;

const { class: className, ...rest } = Astro.props;
---

<SheetPrimitive.Title class={sheetTitle({ class: className })} {...rest} data-slot="sheet-title">
  <slot />
</SheetPrimitive.Title>
