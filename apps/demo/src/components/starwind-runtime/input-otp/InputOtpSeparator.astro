---
import InputOtpPrimitive from "@starwind-ui/astro/input-otp";
import Minus from "@tabler/icons/outline/minus.svg";
import type { HTMLAttributes } from "astro/types";
import { inputOtpSeparator } from "./variants";

type Props = HTMLAttributes<"div">;

const { class: className, ...rest } = Astro.props;
---

<InputOtpPrimitive.Separator
  class={inputOtpSeparator({ class: className })}
  {...rest}
  data-slot="input-otp-separator"
>
  <slot name="icon">
    <Minus class="size-6" />
  </slot>
</InputOtpPrimitive.Separator>
