---
import ContextMenuPrimitive from "@starwind-ui/astro/context-menu";
import type { HTMLAttributes } from "astro/types";
import { contextMenu } from "./variants";

type Props = HTMLAttributes<"div"> & {
  defaultOpen?: boolean;
  disabled?: boolean;
  modal?: boolean;
  closeDelay?: number;
};

const {
  defaultOpen = false,
  disabled = false,
  modal = true,
  closeDelay = 200,
  class: className,
  ...rest
} = Astro.props;
---

<ContextMenuPrimitive.Root
  class={contextMenu({ class: className })}
  defaultOpen={defaultOpen}
  disabled={disabled}
  modal={modal}
  closeDelay={closeDelay}
  {...rest}
  data-slot="context-menu"
>
  <slot />
</ContextMenuPrimitive.Root>
