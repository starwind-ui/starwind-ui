---
import DialogPrimitive from "@starwind-ui/astro/dialog";
import type { HTMLAttributes } from "astro/types";
import { dialogTitle } from "./variants";

type Props = HTMLAttributes<"h2">;

const { class: className, ...rest } = Astro.props;
---

<DialogPrimitive.Title class={dialogTitle({ class: className })} {...rest} data-slot="dialog-title">
  <slot />
</DialogPrimitive.Title>
