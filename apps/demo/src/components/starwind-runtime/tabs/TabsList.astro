---
import TabsPrimitive from "@starwind-ui/astro/tabs";
import type { HTMLAttributes } from "astro/types";
import { tabsList } from "./variants";

type Props = HTMLAttributes<"div"> & {
  activateOnFocus?: boolean;
  loopFocus?: boolean;
};

const { activateOnFocus, loopFocus, class: className, ...rest } = Astro.props;
---

<TabsPrimitive.List
  class={tabsList({ class: className })}
  activateOnFocus={activateOnFocus}
  loopFocus={loopFocus}
  {...rest}
  data-slot="tabs-list"
>
  <slot />
</TabsPrimitive.List>
