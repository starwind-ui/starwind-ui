---
import FieldsetPrimitive from "@starwind-ui/astro/fieldset";
import type { HTMLAttributes } from "astro/types";
import type { VariantProps } from "tailwind-variants";
import { fieldLegend } from "./variants";

type Props = HTMLAttributes<"div"> & VariantProps<typeof fieldLegend>;

const { variant, class: className, ...rest } = Astro.props;
---

<FieldsetPrimitive.Legend
  class={fieldLegend({ variant, class: className })}
  {...rest}
  data-slot="field-legend"
>
  <slot />
</FieldsetPrimitive.Legend>
