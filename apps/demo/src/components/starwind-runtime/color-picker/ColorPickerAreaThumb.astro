---
import ColorPickerPrimitive from "@starwind-ui/astro/color-picker";
import type { HTMLAttributes } from "astro/types";
import type { VariantProps } from "tailwind-variants";
import { colorPickerAreaThumb } from "./variants";

type Props = HTMLAttributes<"span"> &
  VariantProps<typeof colorPickerAreaThumb> & {
    initial?: import("@starwind-ui/astro/color-picker").ColorPickerInitialPartProjection;
  };

const { initial, class: className, size = "md", ...rest } = Astro.props;
---

<ColorPickerPrimitive.AreaThumb
  initial={initial}
  class={colorPickerAreaThumb({ size, class: className })}
  {...rest}
  data-slot="color-picker-area-thumb"
>
  <slot />
</ColorPickerPrimitive.AreaThumb>
