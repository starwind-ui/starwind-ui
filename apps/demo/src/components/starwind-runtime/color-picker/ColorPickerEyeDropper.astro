---
import ColorPickerPrimitive from "@starwind-ui/astro/color-picker";
import type { HTMLAttributes } from "astro/types";
import type { VariantProps } from "tailwind-variants";
import { colorPickerAction } from "./variants";

type Props = HTMLAttributes<"button"> &
  VariantProps<typeof colorPickerAction> & {
    initial?: import("@starwind-ui/astro/color-picker").ColorPickerInitialPartProjection;
  };

const { initial, class: className, size = "md", ...rest } = Astro.props;
---

<ColorPickerPrimitive.EyeDropperTrigger
  initial={initial}
  class={colorPickerAction({ size, class: className })}
  {...rest}
  data-slot="color-picker-eye-dropper"
>
  <slot />
</ColorPickerPrimitive.EyeDropperTrigger>
