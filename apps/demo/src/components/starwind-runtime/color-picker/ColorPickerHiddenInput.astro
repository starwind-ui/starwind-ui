---
import ColorPickerPrimitive from "@starwind-ui/astro/color-picker";
import type { HTMLAttributes } from "astro/types";
import type { VariantProps } from "tailwind-variants";
import { colorPickerHiddenInput } from "./variants";

type Props = HTMLAttributes<"input"> &
  VariantProps<typeof colorPickerHiddenInput> & {
    initial?: import("@starwind-ui/astro/color-picker").ColorPickerInitialPartProjection;
  };

const { initial, class: className, size = "md", ...rest } = Astro.props;
---

<ColorPickerPrimitive.HiddenInput
  initial={initial}
  class={colorPickerHiddenInput({ size, class: className })}
  {...rest}
  data-slot="color-picker-hidden-input"
/>
