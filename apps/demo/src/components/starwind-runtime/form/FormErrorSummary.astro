---
import FormPrimitive from "@starwind-ui/astro/form";
import type { HTMLAttributes } from "astro/types";
import type { VariantProps } from "tailwind-variants";
import { formErrorSummary } from "./variants";

type Props = HTMLAttributes<"div"> & VariantProps<typeof formErrorSummary>;

const { class: className, ...rest } = Astro.props;
---

<FormPrimitive.ErrorSummary
  class={formErrorSummary({ class: className })}
  {...rest}
  data-slot="form-error-summary"
>
  <slot />
</FormPrimitive.ErrorSummary>
