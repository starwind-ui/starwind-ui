---
import { Image as AstroImage } from "astro:assets";

import { image } from "./variants";

type Props = Partial<import("astro/types").ComponentProps<typeof AstroImage>> & {
  inferSize?: boolean;
};

const { class: className, src, alt = "", inferSize = true, ...rest } = Astro.props;
---

{
  src && (
    <AstroImage
      class={image({ class: className })}
      src={src}
      alt={alt}
      inferSize={inferSize}
      {...(rest as any)}
      data-slot="image"
    />
  )
}
