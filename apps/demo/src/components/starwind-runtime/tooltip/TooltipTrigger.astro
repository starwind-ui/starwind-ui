---
import TooltipPrimitive from "@starwind-ui/astro/tooltip";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"span"> & {
  asChild?: boolean;
  disabled?: boolean;
};

const { asChild = true, disabled = false, class: className, ...rest } = Astro.props;

const triggerClassName = [asChild ? "contents" : "inline-flex", className]
  .filter(Boolean)
  .join(" ");
---

<TooltipPrimitive.Trigger
  class={triggerClassName}
  asChild={asChild}
  disabled={disabled}
  {...rest}
  data-slot="tooltip-trigger"
>
  <slot />
</TooltipPrimitive.Trigger>
