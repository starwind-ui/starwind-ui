---
import NavigationMenuPrimitive from "@starwind-ui/astro/navigation-menu";
import type { HTMLAttributes } from "astro/types";
import NavigationMenuPositioner from "./NavigationMenuPositioner.astro";
import { navigationMenu } from "./variants";

type Props = Omit<HTMLAttributes<"nav">, "defaultValue" | "onChange" | "value"> & {
  defaultValue?: string | null;
  value?: string | null;
  openDelay?: number;
  closeDelay?: number;
  closeOnEscape?: boolean;
  closeOnOutsideInteract?: boolean;
  orientation?: "horizontal" | "vertical";
  side?: "top" | "right" | "bottom" | "left";
  align?: "start" | "center" | "end";
  sideOffset?: number;
  alignOffset?: number;
  avoidCollisions?: boolean;
  collisionPadding?: number;
};

const {
  defaultValue = null,
  value,
  openDelay = 50,
  closeDelay = 50,
  closeOnEscape = true,
  closeOnOutsideInteract = true,
  orientation = "horizontal",
  side = "bottom",
  align = "start",
  sideOffset = 8,
  alignOffset = 0,
  avoidCollisions = true,
  collisionPadding = 8,
  class: className,
  ...rest
} = Astro.props;
---

<NavigationMenuPrimitive.Root
  class={navigationMenu({ class: className })}
  defaultValue={defaultValue}
  value={value}
  openDelay={openDelay}
  closeDelay={closeDelay}
  closeOnEscape={closeOnEscape}
  closeOnOutsideInteract={closeOnOutsideInteract}
  orientation={orientation}
  {...rest}
  data-slot="navigation-menu"
>
  <slot />

  <NavigationMenuPositioner
    side={side}
    align={align}
    sideOffset={sideOffset}
    alignOffset={alignOffset}
    avoidCollisions={avoidCollisions}
    collisionPadding={collisionPadding}
  />
</NavigationMenuPrimitive.Root>
