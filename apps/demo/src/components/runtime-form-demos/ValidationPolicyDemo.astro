---
import { Button } from "@/components/starwind-runtime/button";
import {
  Field,
  FieldControl,
  FieldDescription,
  FieldError,
  FieldLabel,
} from "@/components/starwind-runtime/field";
import { Form } from "@/components/starwind-runtime/form";
---

<section class="border-border mb-10 border-b pb-10">
  <div class="mb-5 space-y-2">
    <h2 class="font-heading text-2xl font-semibold tracking-tight">Validation policy sandbox</h2>
    <p class="text-muted-foreground text-sm">
      Choose separate validation triggers before and after the first submit attempt. The default
      starts on submit, then revalidates accepted changes.
    </p>
  </div>

  <div class="mb-5 grid gap-3 sm:grid-cols-3">
    <div class="space-y-2">
      <p class="text-muted-foreground text-sm font-medium">Before submit</p>
      <div class="flex flex-wrap gap-2" data-runtime-policy-validation>
        <Button type="button" size="sm" variant="default" data-policy-value="submit">
          Submit
        </Button>
        <Button type="button" size="sm" variant="outline" data-policy-value="blur">Blur</Button>
        <Button type="button" size="sm" variant="outline" data-policy-value="change">
          Change
        </Button>
      </div>
    </div>
    <div class="space-y-2">
      <p class="text-muted-foreground text-sm font-medium">After submit</p>
      <div class="flex flex-wrap gap-2" data-runtime-policy-revalidation>
        <Button type="button" size="sm" variant="outline" data-policy-value="submit">
          Submit
        </Button>
        <Button type="button" size="sm" variant="outline" data-policy-value="blur">Blur</Button>
        <Button type="button" size="sm" variant="default" data-policy-value="change">
          Change
        </Button>
      </div>
    </div>
    <div class="space-y-2">
      <p class="text-muted-foreground text-sm font-medium">Show errors</p>
      <div class="flex flex-wrap gap-2" data-runtime-policy-visibility>
        <Button type="button" size="sm" variant="default" data-policy-value="submit">
          Submit
        </Button>
        <Button type="button" size="sm" variant="outline" data-policy-value="blur">Blur</Button>
        <Button type="button" size="sm" variant="outline" data-policy-value="change">
          Change
        </Button>
      </div>
    </div>
  </div>

  <Form
    id="runtime-policy-form"
    class="grid gap-4"
    data-validation-timing="submit"
    data-revalidation-timing="change"
    data-error-visibility="submit"
  >
    <Field name="runtimePolicyEmail">
      <FieldLabel>Policy email</FieldLabel>
      <FieldControl id="runtime-policy-email" type="email" required placeholder="ada" />
      <FieldDescription>Uses the selected form policy.</FieldDescription>
      <FieldError match="valueMissing">Enter an email address.</FieldError>
      <FieldError match="typeMismatch">Use a valid email address.</FieldError>
    </Field>

    <Field
      name="runtimePolicyHandle"
      validationTiming="change"
      revalidationTiming="blur"
      errorVisibility="change"
    >
      <FieldLabel>Reverse-policy handle</FieldLabel>
      <FieldControl id="runtime-policy-handle" required minlength="3" placeholder="sw" />
      <FieldDescription
        >This Field validates on change before submit, then only on blur afterward.</FieldDescription
      >
      <FieldError match="valueMissing">Choose a handle.</FieldError>
      <FieldError match="tooShort">Use at least three characters.</FieldError>
    </Field>

    <div class="flex flex-wrap items-center gap-3">
      <Button type="submit">Submit policy form</Button>
      <Button type="reset" variant="ghost">Reset</Button>
    </div>
  </Form>

  <output
    id="runtime-policy-output"
    class="text-muted-foreground mt-3 block text-sm whitespace-pre-wrap"
  >
    Before submit: submit. After submit: change. Errors: submit.
  </output>
</section>

<script>
  const policyForm = document.querySelector<HTMLFormElement>("#runtime-policy-form");
  const policyOutput = document.querySelector<HTMLOutputElement>("#runtime-policy-output");

  const renderPolicyOutput = (text?: string) => {
    if (!policyForm || !policyOutput) return;
    const validation = policyForm.getAttribute("data-validation-timing") ?? "submit";
    const revalidation = policyForm.getAttribute("data-revalidation-timing") ?? "change";
    const visibility = policyForm.getAttribute("data-error-visibility") ?? "submit";
    const nextText =
      text ?? `Before submit: ${validation}. After submit: ${revalidation}. Errors: ${visibility}.`;
    policyOutput.value = nextText;
    policyOutput.textContent = nextText;
  };

  const syncPolicyButtons = (group: Element | null, value: string) => {
    group?.querySelectorAll<HTMLButtonElement>("[data-policy-value]").forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.policyValue === value));
    });
  };

  const setupPolicyGroup = (
    selector: string,
    attributeName: "data-error-visibility" | "data-revalidation-timing" | "data-validation-timing",
  ) => {
    const group = document.querySelector(selector);
    group?.querySelectorAll<HTMLButtonElement>("[data-policy-value]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!policyForm || !button.dataset.policyValue) return;
        policyForm.setAttribute(attributeName, button.dataset.policyValue);
        syncPolicyButtons(group, button.dataset.policyValue);
        renderPolicyOutput();
      });
    });
    if (policyForm) {
      const defaultValue = attributeName === "data-revalidation-timing" ? "change" : "submit";
      syncPolicyButtons(group, policyForm.getAttribute(attributeName) ?? defaultValue);
    }
  };

  policyForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const data = new FormData(policyForm);
    const entries = Array.from(data.entries()).map(([key, value]) => `${key}: ${value}`);
    renderPolicyOutput(entries.length > 0 ? entries.join("\n") : "No enabled fields submitted.");
  });

  policyForm?.addEventListener("reset", () => {
    window.setTimeout(() => renderPolicyOutput(), 0);
  });

  setupPolicyGroup("[data-runtime-policy-validation]", "data-validation-timing");
  setupPolicyGroup("[data-runtime-policy-revalidation]", "data-revalidation-timing");
  setupPolicyGroup("[data-runtime-policy-visibility]", "data-error-visibility");
  renderPolicyOutput();
</script>
