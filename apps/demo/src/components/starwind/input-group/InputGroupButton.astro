---
import type { HTMLAttributes } from "astro/types";
import { tv, type VariantProps } from "tailwind-variants";
import { button as starwindButton } from "../button/Button.astro";

type Props = HTMLAttributes<"button"> & VariantProps<typeof inputGroupButton> & {
  variant?: "default" | "primary" | "secondary" | "outline" | "ghost" | "info" | "success" | "warning" | "error";
};

export const inputGroupButton = tv({
  base: "gap-2 text-sm shadow-none flex items-center",
  variants: {
    size: {
      xs: "h-7 gap-1 rounded-[calc(var(--radius)-3px)] px-1.5 [&>svg:not([class*='size-'])]:size-3.5",
      sm: "h-8 px-2 text-xs",
      "icon-xs": "size-7 rounded-[calc(var(--radius)-3px)] p-0 has-[>svg]:p-0",
      "icon-sm": "size-8 p-0 has-[>svg]:p-0",
    },
  },
  defaultVariants: {
    size: "xs",
  },
});

const { variant = "ghost", size = "xs", class: className, ...rest } = Astro.props;
---

<button
  type="button"
  data-size={size}
  class={starwindButton({ variant, class: inputGroupButton({ size, class: className }) })}
  {...rest}
>
  <slot />
</button>
