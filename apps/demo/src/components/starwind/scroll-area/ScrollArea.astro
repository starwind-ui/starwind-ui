---
import type { HTMLAttributes } from "astro/types";

import ScrollBar from "./ScrollBar.astro";
import { scrollArea } from "./variants";

type Props = HTMLAttributes<"div"> & {
  viewportClass?: string;
};

const { class: className, viewportClass, ...rest } = Astro.props;
const { root, viewport, content, corner } = scrollArea();
---

<div class={root({ class: className })} {...rest} data-slot="scroll-area">
  <div class={viewport({ class: viewportClass })} tabindex="-1" data-slot="scroll-area-viewport">
    <div class={content()} role="presentation" data-slot="scroll-area-content">
      <slot />
    </div>
  </div>
  <slot name="scrollbar">
    <ScrollBar />
  </slot>
  <div class={corner()} aria-hidden="true" data-slot="scroll-area-corner"></div>
</div>

<style is:global>
  .starwind-scroll-area-viewport {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .starwind-scroll-area-viewport::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  type ScrollOrientation = "vertical" | "horizontal";
  type ScrollAxis = "x" | "y";
  type SpacingProperty = "margin" | "padding";

  const MIN_THUMB_SIZE = 20;

  const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

  const parseCssPixelValue = (value: string) => {
    const parsed = Number.parseFloat(value);

    return Number.isFinite(parsed) ? parsed : 0;
  };

  const getPhysicalSpacing = (
    element: Element,
    property: SpacingProperty,
    orientation: ScrollOrientation,
  ) => {
    const styles = getComputedStyle(element);

    if (orientation === "horizontal") {
      return {
        start: parseCssPixelValue(styles.getPropertyValue(`${property}-left`)),
        end: parseCssPixelValue(styles.getPropertyValue(`${property}-right`)),
      };
    }

    return {
      start: parseCssPixelValue(styles.getPropertyValue(`${property}-top`)),
      end: parseCssPixelValue(styles.getPropertyValue(`${property}-bottom`)),
    };
  };

  const getSpacing = (
    element: Element | null,
    property: SpacingProperty,
    axis: ScrollAxis,
  ): number => {
    if (!element) return 0;

    const styles = getComputedStyle(element);

    if (axis === "x" && property === "margin") {
      return parseCssPixelValue(styles.getPropertyValue("margin-inline-start")) * 2;
    }

    const propertyAxis = axis === "x" ? "inline" : "block";

    return (
      parseCssPixelValue(styles.getPropertyValue(`${property}-${propertyAxis}-start`)) +
      parseCssPixelValue(styles.getPropertyValue(`${property}-${propertyAxis}-end`))
    );
  };

  class ScrollAreaHandler {
    private root: HTMLElement;
    private viewport: HTMLElement;
    private content: HTMLElement | null;
    private scrollbars: HTMLElement[];
    private corner: HTMLElement | null;
    private resizeObserver: ResizeObserver;
    private mutationObserver: MutationObserver;

    constructor(root: HTMLElement) {
      this.root = root;
      this.viewport = root.querySelector<HTMLElement>(".starwind-scroll-area-viewport")!;
      this.content = root.querySelector<HTMLElement>(".starwind-scroll-area-content");
      this.scrollbars = Array.from(
        root.querySelectorAll<HTMLElement>(".starwind-scroll-area-scrollbar"),
      ).filter((scrollbar) => scrollbar.closest(".starwind-scroll-area") === root);
      this.corner =
        Array.from(root.querySelectorAll<HTMLElement>(".starwind-scroll-area-corner")).find(
          (corner) => corner.closest(".starwind-scroll-area") === root,
        ) ?? null;
      this.resizeObserver = new ResizeObserver(() => this.update());
      this.mutationObserver = new MutationObserver(() => this.update());

      this.setupScrollbars();
      this.setupObservers();
      this.viewport.addEventListener("scroll", () => this.update());
      requestAnimationFrame(() => this.update());
    }

    private setupScrollbars(): void {
      this.scrollbars.forEach((scrollbar) => {
        const thumb = scrollbar.querySelector<HTMLElement>(".starwind-scroll-area-thumb");
        if (!thumb) return;

        thumb.style.flex = "0 0 auto";
        thumb.dataset.orientation = this.getOrientation(scrollbar);
        thumb.addEventListener("pointerdown", (event) =>
          this.handleThumbPointerDown(event, scrollbar, thumb),
        );
        scrollbar.addEventListener("pointerdown", (event) =>
          this.handleScrollbarPointerDown(event, scrollbar, thumb),
        );
        scrollbar.addEventListener(
          "wheel",
          (event) => this.handleScrollbarWheel(event, scrollbar),
          {
            passive: false,
          },
        );
      });
    }

    private setupObservers(): void {
      this.resizeObserver.observe(this.root);
      this.resizeObserver.observe(this.viewport);
      if (this.content) {
        this.resizeObserver.observe(this.content);
      }
      this.mutationObserver.observe(this.viewport, {
        childList: true,
        subtree: true,
        characterData: true,
      });
    }

    private getOrientation(scrollbar: HTMLElement): ScrollOrientation {
      return scrollbar.dataset.orientation === "horizontal" ? "horizontal" : "vertical";
    }

    private hasOverflow(orientation: ScrollOrientation): boolean {
      if (orientation === "horizontal") {
        return this.viewport.scrollWidth > this.viewport.clientWidth + 1;
      }

      return this.viewport.scrollHeight > this.viewport.clientHeight + 1;
    }

    private isRtl(): boolean {
      return getComputedStyle(this.viewport).direction === "rtl";
    }

    private getScrollbar(orientation: ScrollOrientation): HTMLElement | undefined {
      return this.scrollbars.find((scrollbar) => this.getOrientation(scrollbar) === orientation);
    }

    private getScrollSize(orientation: ScrollOrientation): number {
      return orientation === "horizontal" ? this.viewport.scrollWidth : this.viewport.scrollHeight;
    }

    private getViewportSize(orientation: ScrollOrientation): number {
      return orientation === "horizontal" ? this.viewport.clientWidth : this.viewport.clientHeight;
    }

    private getMaxScrollOffset(orientation: ScrollOrientation): number {
      return Math.max(this.getScrollSize(orientation) - this.getViewportSize(orientation), 0);
    }

    private getScrollPosition(orientation: ScrollOrientation): number {
      const maxScrollOffset = this.getMaxScrollOffset(orientation);

      if (orientation === "horizontal") {
        return clamp(
          this.isRtl() ? -this.viewport.scrollLeft : this.viewport.scrollLeft,
          0,
          maxScrollOffset,
        );
      }

      return clamp(this.viewport.scrollTop, 0, maxScrollOffset);
    }

    private setScrollPosition(orientation: ScrollOrientation, position: number): void {
      const nextPosition = clamp(position, 0, this.getMaxScrollOffset(orientation));

      if (orientation === "horizontal") {
        this.viewport.scrollLeft = this.isRtl() ? -nextPosition : nextPosition;
      } else {
        this.viewport.scrollTop = nextPosition;
      }
    }

    private getThumbMetrics(
      scrollbar: HTMLElement,
      thumb: HTMLElement,
      orientation: ScrollOrientation,
    ) {
      const axis = orientation === "horizontal" ? "x" : "y";
      const isHorizontal = orientation === "horizontal";
      const viewportSize = this.getViewportSize(orientation);
      const scrollSize = this.getScrollSize(orientation);
      const scrollbarSize = isHorizontal ? scrollbar.clientWidth : scrollbar.clientHeight;
      const scrollbarPadding = getSpacing(scrollbar, "padding", axis);
      const thumbMargin = getSpacing(thumb, "margin", axis);
      const trackSize = Math.max(scrollbarSize - scrollbarPadding - thumbMargin, 0);
      const thumbSize =
        trackSize > 0
          ? Math.min(Math.max((viewportSize / scrollSize) * trackSize, MIN_THUMB_SIZE), trackSize)
          : 0;
      const maxThumbOffset = Math.max(trackSize - thumbSize, 0);
      const maxScrollOffset = Math.max(scrollSize - viewportSize, 0);

      return {
        maxScrollOffset,
        maxThumbOffset,
        thumbSize,
      };
    }

    private updateLayout(hasVerticalOverflow: boolean, hasHorizontalOverflow: boolean): void {
      const verticalScrollbar = this.getScrollbar("vertical");
      const horizontalScrollbar = this.getScrollbar("horizontal");
      const shouldShowCorner = Boolean(
        hasVerticalOverflow && hasHorizontalOverflow && verticalScrollbar && horizontalScrollbar,
      );

      if (this.corner) {
        this.corner.style.display = shouldShowCorner ? "block" : "none";

        if (shouldShowCorner && verticalScrollbar && horizontalScrollbar) {
          this.corner.style.width = `${verticalScrollbar.offsetWidth}px`;
          this.corner.style.height = `${horizontalScrollbar.offsetHeight}px`;
        } else {
          this.corner.style.width = "";
          this.corner.style.height = "";
        }
      }

      if (verticalScrollbar) {
        verticalScrollbar.style.bottom =
          shouldShowCorner && horizontalScrollbar ? `${horizontalScrollbar.offsetHeight}px` : "";
      }

      if (horizontalScrollbar) {
        horizontalScrollbar.style.insetInlineEnd =
          shouldShowCorner && verticalScrollbar ? `${verticalScrollbar.offsetWidth}px` : "";
      }
    }

    private update(): void {
      let hasVerticalOverflow = false;
      let hasHorizontalOverflow = false;
      let hasVerticalScrollbar = false;
      let hasHorizontalScrollbar = false;

      this.scrollbars.forEach((scrollbar) => {
        const orientation = this.getOrientation(scrollbar);
        const thumb = scrollbar.querySelector<HTMLElement>(".starwind-scroll-area-thumb");
        const isOverflowing = this.hasOverflow(orientation);

        if (orientation === "vertical") {
          hasVerticalOverflow = isOverflowing;
          hasVerticalScrollbar = true;
        } else {
          hasHorizontalOverflow = isOverflowing;
          hasHorizontalScrollbar = true;
        }

        scrollbar.style.display = isOverflowing ? "flex" : "none";

        if (!thumb) return;

        thumb.dataset.orientation = orientation;
      });

      this.viewport.tabIndex = hasVerticalOverflow || hasHorizontalOverflow ? 0 : -1;
      this.updateLayout(
        hasVerticalOverflow && hasVerticalScrollbar,
        hasHorizontalOverflow && hasHorizontalScrollbar,
      );

      this.scrollbars.forEach((scrollbar) => {
        const orientation = this.getOrientation(scrollbar);
        const thumb = scrollbar.querySelector<HTMLElement>(".starwind-scroll-area-thumb");

        if (!thumb || !this.hasOverflow(orientation)) return;

        this.updateThumb(scrollbar, thumb, orientation);
      });
    }

    private updateThumb(
      scrollbar: HTMLElement,
      thumb: HTMLElement,
      orientation: ScrollOrientation,
    ): void {
      const isHorizontal = orientation === "horizontal";
      const { maxScrollOffset, maxThumbOffset, thumbSize } = this.getThumbMetrics(
        scrollbar,
        thumb,
        orientation,
      );
      const scrollPosition = this.getScrollPosition(orientation);
      const thumbOffset =
        maxScrollOffset === 0 ? 0 : (scrollPosition / maxScrollOffset) * maxThumbOffset;

      if (isHorizontal) {
        thumb.style.width = `${thumbSize}px`;
        thumb.style.height = "100%";
        thumb.style.transform = `translateX(${this.isRtl() ? -thumbOffset : thumbOffset}px)`;
      } else {
        thumb.style.height = `${thumbSize}px`;
        thumb.style.width = "100%";
        thumb.style.transform = `translateY(${thumbOffset}px)`;
      }
    }

    private handleScrollbarPointerDown(
      event: PointerEvent,
      scrollbar: HTMLElement,
      thumb: HTMLElement,
    ): void {
      if (event.button !== 0 || !event.isPrimary || thumb.contains(event.target as Node)) return;

      event.preventDefault();
      const orientation = this.getOrientation(scrollbar);
      const isHorizontal = orientation === "horizontal";
      const rect = scrollbar.getBoundingClientRect();
      const scrollbarPadding = getPhysicalSpacing(scrollbar, "padding", orientation);
      const thumbMargin = getPhysicalSpacing(thumb, "margin", orientation);
      const pointerPosition = isHorizontal
        ? this.isRtl()
          ? rect.right - event.clientX - scrollbarPadding.end - thumbMargin.end
          : event.clientX - rect.left - scrollbarPadding.start - thumbMargin.start
        : event.clientY - rect.top - scrollbarPadding.start - thumbMargin.start;
      const { maxScrollOffset, maxThumbOffset, thumbSize } = this.getThumbMetrics(
        scrollbar,
        thumb,
        orientation,
      );

      if (maxThumbOffset === 0) return;

      const nextThumbOffset = Math.min(
        Math.max(pointerPosition - thumbSize / 2, 0),
        maxThumbOffset,
      );
      const nextScrollPosition = (nextThumbOffset / maxThumbOffset) * maxScrollOffset;

      this.setScrollPosition(orientation, nextScrollPosition);
    }

    private handleScrollbarWheel(event: WheelEvent, scrollbar: HTMLElement): void {
      const orientation = this.getOrientation(scrollbar);
      const isHorizontal = orientation === "horizontal";

      if (event.ctrlKey || !this.hasOverflow(orientation)) return;

      const delta = isHorizontal ? event.deltaX : event.deltaY;
      if (delta === 0) return;

      const scrollProperty = isHorizontal ? "scrollLeft" : "scrollTop";
      const maxScrollOffset = this.getMaxScrollOffset(orientation);
      const minScroll = isHorizontal && this.isRtl() ? -maxScrollOffset : 0;
      const maxScroll = isHorizontal && this.isRtl() ? 0 : maxScrollOffset;
      const scrollPosition = this.viewport[scrollProperty];
      const nextScrollPosition = clamp(scrollPosition + delta, minScroll, maxScroll);

      if (nextScrollPosition === scrollPosition) return;

      event.preventDefault();
      this.viewport[scrollProperty] = nextScrollPosition;
    }

    private handleThumbPointerDown(
      event: PointerEvent,
      scrollbar: HTMLElement,
      thumb: HTMLElement,
    ): void {
      if (event.button !== 0 || !event.isPrimary) return;

      event.preventDefault();

      const orientation = this.getOrientation(scrollbar);
      const isHorizontal = orientation === "horizontal";
      const startPointerPosition = isHorizontal ? event.clientX : event.clientY;
      const startScrollPosition = this.getScrollPosition(orientation);
      const { maxScrollOffset, maxThumbOffset } = this.getThumbMetrics(
        scrollbar,
        thumb,
        orientation,
      );

      if (maxThumbOffset === 0) return;

      if (!thumb.hasPointerCapture(event.pointerId)) {
        thumb.setPointerCapture(event.pointerId);
      }

      const handlePointerMove = (moveEvent: PointerEvent) => {
        const pointerPosition = isHorizontal ? moveEvent.clientX : moveEvent.clientY;
        const delta =
          isHorizontal && this.isRtl()
            ? startPointerPosition - pointerPosition
            : pointerPosition - startPointerPosition;
        const nextScrollPosition = startScrollPosition + (delta / maxThumbOffset) * maxScrollOffset;

        this.setScrollPosition(orientation, nextScrollPosition);
      };

      const handlePointerUp = (upEvent: PointerEvent) => {
        if (thumb.hasPointerCapture(upEvent.pointerId)) {
          thumb.releasePointerCapture(upEvent.pointerId);
        }
        thumb.removeEventListener("pointermove", handlePointerMove);
        thumb.removeEventListener("pointerup", handlePointerUp);
        thumb.removeEventListener("pointercancel", handlePointerUp);
      };

      thumb.addEventListener("pointermove", handlePointerMove);
      thumb.addEventListener("pointerup", handlePointerUp);
      thumb.addEventListener("pointercancel", handlePointerUp);
    }
  }

  const scrollAreaInstances = new WeakMap<HTMLElement, ScrollAreaHandler>();

  const setupScrollAreas = () => {
    document.querySelectorAll<HTMLElement>(".starwind-scroll-area").forEach((root) => {
      if (!scrollAreaInstances.has(root) && root.querySelector(".starwind-scroll-area-viewport")) {
        scrollAreaInstances.set(root, new ScrollAreaHandler(root));
      }
    });
  };

  setupScrollAreas();
  document.addEventListener("astro:after-swap", setupScrollAreas);
  document.addEventListener("starwind:init", setupScrollAreas);
</script>
