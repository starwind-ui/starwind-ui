---
import type { HTMLAttributes } from "astro/types";

import { hoverCardTrigger } from "./variants";

type Props = Omit<HTMLAttributes<"button">, "type"> & {
  /**
   * When true, the component will render its child element with a simple wrapper instead of a button component
   */
  asChild?: boolean;
};

const { class: className, asChild = false, ...rest } = Astro.props;

let hasChildren = false;
if (Astro.slots.has("default")) {
  hasChildren = true;
}
---

{
  asChild && hasChildren ? (
    <div
      class:list={["starwind-hover-card-trigger", className]}
      data-as-child
      {...rest}
      data-slot="hover-card-trigger"
    >
      <slot />
    </div>
  ) : (
    <button
      class={hoverCardTrigger({ class: className })}
      type="button"
      data-state="closed"
      {...rest}
      data-slot="hover-card-trigger"
    >
      <slot />
    </button>
  )
}
