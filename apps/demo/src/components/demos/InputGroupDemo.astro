---
import Copy from "@tabler/icons/outline/copy.svg";
import Mail from "@tabler/icons/outline/mail.svg";
import Search from "@tabler/icons/outline/search.svg";
import Settings from "@tabler/icons/outline/settings.svg";

import {
  InputGroup,
  InputGroupAddon,
  InputGroupButton,
  InputGroupInput,
  InputGroupText,
} from "../starwind/input-group";
---

<section class="mx-auto mt-10 max-w-lg">
  <h2 class="mb-4 text-2xl font-bold">Input Group</h2>
  <div class="space-y-8">
    <!-- Basic Example -->
    <div class="space-y-2">
      <p class="text-sm font-medium">Basic Addon</p>
      <InputGroup>
        <InputGroupAddon align="inline-start">
          <Mail class="size-4" />
        </InputGroupAddon>
        <InputGroupInput placeholder="Email" />
      </InputGroup>
    </div>

    <!-- With Button -->
    <div class="space-y-2">
      <p class="text-sm font-medium">With Button</p>
      <InputGroup>
        <InputGroupInput placeholder="Search..." />
        <InputGroupAddon align="inline-end">
          <InputGroupButton>
            <Search class="size-4" />
          </InputGroupButton>
        </InputGroupAddon>
      </InputGroup>
    </div>

    <!-- Sizes -->
    <div class="space-y-2">
      <p class="text-sm font-medium">Sizes (sm, md, lg)</p>
      <div class="space-y-4">
        <InputGroup size="sm">
          <InputGroupAddon align="inline-start">
            <InputGroupText>https://</InputGroupText>
          </InputGroupAddon>
          <InputGroupInput size="sm" placeholder="example.com" />
        </InputGroup>

        <InputGroup size="md">
          <InputGroupAddon align="inline-start">
            <InputGroupText>https://</InputGroupText>
          </InputGroupAddon>
          <InputGroupInput size="md" placeholder="example.com" />
        </InputGroup>

        <InputGroup size="lg">
          <InputGroupAddon align="inline-start">
            <InputGroupText>https://</InputGroupText>
          </InputGroupAddon>
          <InputGroupInput size="lg" placeholder="example.com" />
        </InputGroup>
      </div>
    </div>

    <!-- Multiple Addons -->
    <div class="space-y-2">
      <p class="text-sm font-medium">Multiple Addons</p>
      <InputGroup>
        <InputGroupAddon align="inline-start">
          <Settings class="size-4" />
        </InputGroupAddon>
        <InputGroupAddon align="inline-start">
          <InputGroupText>$</InputGroupText>
        </InputGroupAddon>
        <InputGroupInput placeholder="Amount" />
        <InputGroupAddon align="inline-end">
          <InputGroupText>.00</InputGroupText>
        </InputGroupAddon>
        <InputGroupAddon align="inline-end">
          <InputGroupButton variant="outline" size="sm"> Action </InputGroupButton>
        </InputGroupAddon>
      </InputGroup>
    </div>

    <!-- Copy Link style -->
    <div class="space-y-2">
      <p class="text-sm font-medium">Copy Link Example</p>
      <InputGroup>
        <InputGroupInput value="https://starwind-ui.com" readonly />
        <InputGroupAddon align="inline-end">
          <InputGroupButton variant="outline" size="sm">
            <Copy class="size-4" />
            Copy
          </InputGroupButton>
        </InputGroupAddon>
      </InputGroup>
    </div>

    <!-- Block Alignments -->
    <div class="space-y-2">
      <p class="text-sm font-medium">Block Alignments (Vertical Stack)</p>
      <div class="space-y-4">
        <InputGroup>
          <InputGroupAddon align="block-start">
            <InputGroupText>Top Label</InputGroupText>
          </InputGroupAddon>
          <InputGroupInput placeholder="Input with top label" />
        </InputGroup>

        <InputGroup>
          <InputGroupInput placeholder="Input with bottom label" />
          <InputGroupAddon align="block-end">
            <InputGroupText>Bottom Label</InputGroupText>
          </InputGroupAddon>
        </InputGroup>
      </div>
    </div>
  </div>
</section>
