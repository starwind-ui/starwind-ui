---
import "@/styles/global.css";

import { ThemeInitScript } from "@starwind-ui/astro/theme";
import Bell from "@tabler/icons/outline/bell.svg";
import Calendar from "@tabler/icons/outline/calendar.svg";
import ChevronUp from "@tabler/icons/outline/chevron-up.svg";
import CreditCard from "@tabler/icons/outline/credit-card.svg";
import Home from "@tabler/icons/outline/home.svg";
import Inbox from "@tabler/icons/outline/inbox.svg";
import Logout from "@tabler/icons/outline/logout.svg";
import BadgeCheck from "@tabler/icons/outline/rosette-discount-check.svg";
import Search from "@tabler/icons/outline/search.svg";
import Settings from "@tabler/icons/outline/settings.svg";
import Sparkles from "@tabler/icons/outline/sparkles.svg";
import User from "@tabler/icons/outline/user.svg";
import { Avatar, AvatarFallback, AvatarImage } from "@/components/starwind-runtime/avatar";
import {
  Dropdown,
  DropdownContent,
  DropdownItem,
  DropdownLabel,
  DropdownSeparator,
  DropdownTrigger,
} from "@/components/starwind-runtime/dropdown";
import {
  Sidebar,
  SidebarContent,
  SidebarFooter,
  SidebarGroup,
  SidebarGroupContent,
  SidebarGroupLabel,
  SidebarHeader,
  SidebarInput,
  SidebarInset,
  SidebarMenu,
  SidebarMenuButton,
  SidebarMenuItem,
  SidebarProvider,
  SidebarRail,
  SidebarSeparator,
  SidebarTrigger,
} from "@/components/starwind-runtime/sidebar";
import { ThemeToggle } from "@/components/starwind-runtime/theme-toggle";

const menuItems = [
  { title: "Home", url: "#", icon: Home },
  { title: "Inbox", url: "#", icon: Inbox },
  { title: "Calendar", url: "#", icon: Calendar },
  { title: "Search", url: "#", icon: Search },
  { title: "Settings", url: "#", icon: Settings },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Runtime Sidebar Demo - Starwind UI</title>
    <meta name="description" content="Runtime sidebar component demo for Starwind UI" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <ThemeInitScript />
  </head>

  <body class="min-h-lvh">
    <div id="runtime-sidebar-demo" class="min-h-lvh">
      <SidebarProvider
        keyboardShortcut="b"
        persistOpen
        persistenceStorage="cookie"
        persistenceKey="starwind-runtime-sidebar-demo-open"
      >
        <Sidebar collapsible="icon" variant="inset">
          <SidebarHeader>
            <SidebarMenu>
              <SidebarMenuItem>
                <SidebarMenuButton variant="outline" size="lg">
                  <div
                    class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-10 items-center justify-center rounded-lg"
                  >
                    <span class="text-lg font-bold">S</span>
                  </div>
                  <div class="grid flex-1 text-left text-sm leading-tight">
                    <span class="truncate font-semibold">Starwind UI</span>
                    <span class="text-sidebar-foreground/70 truncate text-xs">Runtime App</span>
                  </div>
                </SidebarMenuButton>
              </SidebarMenuItem>
            </SidebarMenu>

            <div class="relative group-data-[collapsible=icon]:hidden">
              <Search
                class="text-muted-foreground pointer-events-none absolute top-1/2 left-3 size-4 -translate-y-1/2"
                aria-hidden="true"
              />
              <SidebarInput placeholder="Search workspace" class="pl-9" />
            </div>
          </SidebarHeader>

          <SidebarSeparator />

          <SidebarContent>
            <SidebarGroup>
              <SidebarGroupLabel>Application</SidebarGroupLabel>
              <SidebarGroupContent>
                <SidebarMenu>
                  {
                    menuItems.map((item) => (
                      <SidebarMenuItem>
                        <SidebarMenuButton
                          href={item.url}
                          isActive={item.title === "Home"}
                          tooltip={item.title}
                          variant="outline"
                        >
                          <item.icon aria-hidden="true" />
                          <span>{item.title}</span>
                        </SidebarMenuButton>
                      </SidebarMenuItem>
                    ))
                  }
                </SidebarMenu>
              </SidebarGroupContent>
            </SidebarGroup>

            <SidebarGroup>
              <SidebarGroupLabel>Projects</SidebarGroupLabel>
              <SidebarGroupContent>
                <SidebarMenu>
                  <SidebarMenuItem>
                    <SidebarMenuButton variant="outline" href="#" tooltip="Project Alpha">
                      <span
                        class="flex size-4.5 shrink-0 items-center justify-center rounded-sm bg-blue-500 text-[10px] text-white"
                        >P1</span
                      >
                      <span>Project Alpha</span>
                    </SidebarMenuButton>
                  </SidebarMenuItem>
                  <SidebarMenuItem>
                    <SidebarMenuButton variant="outline" href="#" tooltip="Project Beta">
                      <span
                        class="flex size-4.5 shrink-0 items-center justify-center rounded-sm bg-green-500 text-[10px] text-white"
                        >P2</span
                      >
                      <span>Project Beta</span>
                    </SidebarMenuButton>
                  </SidebarMenuItem>
                  <SidebarMenuItem>
                    <SidebarMenuButton variant="outline" href="#" tooltip="Project Gamma">
                      <span
                        class="flex size-4.5 shrink-0 items-center justify-center rounded-sm bg-purple-500 text-[10px] text-white"
                        >P3</span
                      >
                      <span>Project Gamma</span>
                    </SidebarMenuButton>
                  </SidebarMenuItem>
                </SidebarMenu>
              </SidebarGroupContent>
            </SidebarGroup>
          </SidebarContent>

          <SidebarFooter>
            <SidebarMenu>
              <SidebarMenuItem>
                <Dropdown>
                  <DropdownTrigger asChild>
                    <SidebarMenuButton
                      variant="outline"
                      size="lg"
                      class="data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground"
                    >
                      <Avatar class="shrink-0 rounded-lg">
                        <AvatarImage src="https://i.pravatar.cc/150?u=johndoe" alt="John Doe" />
                        <AvatarFallback class="rounded-lg">JD</AvatarFallback>
                      </Avatar>
                      <div class="grid flex-1 text-left text-sm leading-tight">
                        <span class="truncate font-semibold">John Doe</span>
                        <span class="text-sidebar-foreground/70 truncate text-xs">
                          john@example.com
                        </span>
                      </div>
                      <ChevronUp class="ml-auto size-4" aria-hidden="true" />
                    </SidebarMenuButton>
                  </DropdownTrigger>
                  <DropdownContent
                    class="w-[--trigger-width] min-w-56 rounded-lg"
                    side="right"
                    align="end"
                    sideOffset={4}
                  >
                    <DropdownLabel class="p-0 font-normal">
                      <div class="flex items-center gap-2 px-1 py-1.5 text-left text-sm">
                        <Avatar class="size-8 rounded-lg">
                          <AvatarImage src="https://i.pravatar.cc/150?u=johndoe" alt="John Doe" />
                          <AvatarFallback class="rounded-lg">JD</AvatarFallback>
                        </Avatar>
                        <div class="grid flex-1 text-left text-sm leading-tight">
                          <span class="truncate font-semibold">John Doe</span>
                          <span class="text-muted-foreground truncate text-xs">
                            john@example.com
                          </span>
                        </div>
                      </div>
                    </DropdownLabel>
                    <DropdownSeparator />
                    <DropdownItem>
                      <Sparkles class="mr-2 size-4" aria-hidden="true" />
                      Upgrade to Pro
                    </DropdownItem>
                    <DropdownSeparator />
                    <DropdownItem>
                      <BadgeCheck class="mr-2 size-4" aria-hidden="true" />
                      Account
                    </DropdownItem>
                    <DropdownItem>
                      <CreditCard class="mr-2 size-4" aria-hidden="true" />
                      Billing
                    </DropdownItem>
                    <DropdownItem>
                      <Bell class="mr-2 size-4" aria-hidden="true" />
                      Notifications
                    </DropdownItem>
                    <DropdownSeparator />
                    <DropdownItem>
                      <Logout class="mr-2 size-4" aria-hidden="true" />
                      Log out
                    </DropdownItem>
                  </DropdownContent>
                </Dropdown>
              </SidebarMenuItem>
            </SidebarMenu>
          </SidebarFooter>

          <SidebarRail />
        </Sidebar>

        <SidebarInset>
          <header class="bg-background sticky top-0 flex h-14 items-center gap-4 border-b px-4">
            <SidebarTrigger id="runtime-sidebar-trigger" />
            <div class="flex-1">
              <h1 class="text-lg font-semibold">Runtime Sidebar Demo</h1>
            </div>
            <nav
              class="hidden items-center gap-2 sm:flex"
              aria-label="Runtime sidebar page navigation"
            >
              <a
                href="/runtime-prototype/"
                class="border-input bg-background hover:bg-muted hover:text-foreground rounded-md border px-3 py-1.5 text-sm font-medium shadow-xs transition-colors"
              >
                Prototype
              </a>
              <a
                href="/pages/runtime-nested-sidebar"
                class="border-input bg-background hover:bg-muted hover:text-foreground rounded-md border px-3 py-1.5 text-sm font-medium shadow-xs transition-colors"
              >
                Nested
              </a>
            </nav>
            <ThemeToggle />
          </header>

          <main class="flex-1 p-6">
            <div class="mx-auto max-w-4xl space-y-8">
              <section>
                <h2 class="mb-4 text-2xl font-bold">Starwind UI Runtime Sidebar Component</h2>
                <p class="text-muted-foreground mb-6">
                  A composable, themeable, and customizable sidebar component backed by the portable
                  runtime. This demo showcases the
                  <code class="bg-muted rounded px-1.5 py-0.5 text-sm">collapsible="icon"</code>
                  mode.
                </p>

                <div class="bg-muted/50 space-y-4 rounded-lg border p-6">
                  <h3 class="font-semibold">Features</h3>
                  <ul class="text-muted-foreground list-inside list-disc space-y-2 text-sm">
                    <li>
                      <strong>Collapsible modes:</strong>
                      <code class="bg-muted rounded px-1 text-xs">icon</code>,
                      <code class="bg-muted rounded px-1 text-xs">offcanvas</code>, or
                      <code class="bg-muted rounded px-1 text-xs">none</code>
                    </li>
                    <li>
                      <strong>Side positioning:</strong>
                      <code class="bg-muted rounded px-1 text-xs">left</code> or
                      <code class="bg-muted rounded px-1 text-xs">right</code>
                    </li>
                    <li>
                      <strong>Variants:</strong>
                      <code class="bg-muted rounded px-1 text-xs">sidebar</code>,
                      <code class="bg-muted rounded px-1 text-xs">floating</code>, or
                      <code class="bg-muted rounded px-1 text-xs">inset</code>
                    </li>
                    <li>
                      <strong>Keyboard shortcut:</strong> Press
                      <kbd class="bg-muted rounded border px-1.5 py-0.5 font-mono text-xs">Ctrl</kbd
                      >
                      +
                      <kbd class="bg-muted rounded border px-1.5 py-0.5 font-mono text-xs">B</kbd>
                      to toggle
                    </li>
                    <li>
                      <strong>Opt-in cookie persistence:</strong> Remembers desktop sidebar state across
                      sessions
                    </li>
                    <li><strong>Mobile support:</strong> Opens as a sheet on mobile devices</li>
                  </ul>
                </div>
              </section>

              <section>
                <h3 class="mb-4 text-xl font-semibold">Usage</h3>
                <pre
                  class="bg-muted overflow-x-auto rounded-lg border p-4 text-sm"><code>{`<SidebarProvider
  persistOpen
  persistenceStorage="cookie"
  persistenceKey="starwind-runtime-sidebar-demo-open"
>
  <Sidebar collapsible="icon">
    <SidebarHeader>...</SidebarHeader>
    <SidebarContent>
      <SidebarGroup>
        <SidebarGroupLabel>Menu</SidebarGroupLabel>
        <SidebarGroupContent>
          <SidebarMenu>
            <SidebarMenuItem>
              <SidebarMenuButton href="#">
                <Icon />
                <span>Label</span>
              </SidebarMenuButton>
            </SidebarMenuItem>
          </SidebarMenu>
        </SidebarGroupContent>
      </SidebarGroup>
    </SidebarContent>
    <SidebarFooter>...</SidebarFooter>
    <SidebarRail />
  </Sidebar>

  <SidebarInset>
    <main>Your content here</main>
  </SidebarInset>
</SidebarProvider>`}</code></pre>
              </section>

              <section>
                <h3 class="mb-4 text-xl font-semibold">Try It</h3>
                <div class="flex flex-wrap gap-4">
                  <button
                    type="button"
                    class="bg-primary text-primary-foreground hover:bg-primary/90 rounded-md px-4 py-2 text-sm font-medium transition-colors"
                    onclick="document.querySelector('[data-slot=sidebar-provider]')?.dispatchEvent(new CustomEvent('sidebar:toggle'))"
                  >
                    Toggle Sidebar
                  </button>
                  <a
                    href="/pages/runtime-nested-sidebar"
                    class="bg-secondary text-secondary-foreground hover:bg-secondary/80 rounded-md px-4 py-2 text-sm font-medium transition-colors"
                  >
                    Nested runtime demo
                  </a>
                  <a
                    href="/runtime-prototype/"
                    class="bg-foreground text-background hover:bg-foreground/90 rounded-md px-4 py-2 text-sm font-medium transition-colors"
                  >
                    Back to runtime prototype
                  </a>
                </div>
              </section>
            </div>
          </main>
        </SidebarInset>
      </SidebarProvider>
    </div>
  </body>
</html>

<style>
  html {
    scrollbar-gutter: stable;
  }
</style>
