import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Portable Runtime Prototype"
  description="Button and Accordion prototype for the Starwind portable runtime"
>
  <main class="container mx-auto max-w-4xl px-4 py-12">
    <div class="mb-10 space-y-3">
      <h1 class="font-heading text-4xl font-semibold tracking-tight">Portable runtime prototype</h1>
      <p class="text-muted-foreground max-w-2xl">
        Generated styled Astro wrappers backed by the new runtime package. Button, Collapsible,
        Accordion, and Dialog self-initialize through their root component scripts.
      </p>
    </div>

