---
import { ThemeInitScript } from "@starwind-ui/astro/theme";
import Nav from "@/components/nav/Nav.astro";
import { Toaster } from "@/components/starwind/toast";

interface Props {
  title: string;
  description: string;
}

import "@/styles/global.css";

const { title, description } = Astro.props;

import interVariable from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2";
---

<!doctype html>
<html lang="en" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- local font preload for better performance -->
    <link rel="preload" href={interVariable} as="font" type="font/woff2" crossorigin="anonymous" />

    <ThemeInitScript />
  </head>

  <body class="min-h-lvh">
    <Nav />
    <main>
      <slot />
    </main>
    <Toaster position="bottom-right" />
  </body>
</html>

<style>
  html {
    scrollbar-gutter: stable;
  }
</style>
