{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starwind-ui/starwind-ui.git"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "reset": "pnpm clean:node && pnpm install && pnpm build",
    "clean": "turbo clean",
    "clean:node": "node scripts/clean.mjs",
    "format": "prettier -w . --ignore-unknown --cache && eslint . --fix --cache && biome check --write --formatter-enabled=false --diagnostic-level=warn",
    "format:biome": "biome check --write --formatter-enabled=false --diagnostic-level=info",
    "format:code:ci": "biome format && prettier -w . --ignore-unknown --cache --check",
    "format:imports:ci": "biome ci --formatter-enabled=false --diagnostic-level=warn",
    "format:write": "turbo run format:write",
    "format:check": "turbo run format:check",
    "lint:check": "eslint . --cache",
    "test": "vitest",
    "test:run": "vitest run",
    "test:all": "pnpm test:run && pnpm runtime:test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "pnpm test:coverage && pnpm runtime:test:coverage",
    "test:homes": "node scripts/check-test-homes.mjs",
    "cli:dev": "pnpm --filter=starwind dev",
    "cli:build": "pnpm --filter=starwind build",
    "cli:start": "pnpm --filter=starwind start:dev",
    "cli:link": "pnpm --filter=starwind cli:link",
    "cli:unlink": "pnpm --filter=starwind cli:unlink",
    "astro:link": "pnpm --dir packages/astro add --global . --ignore-scripts",
    "astro:unlink": "pnpm rm --global @starwind-ui/astro",
    "react:build": "pnpm --filter=@starwind-ui/react build",
    "react:link": "pnpm --dir packages/react add --global . --ignore-scripts",
    "react:unlink": "pnpm rm --global @starwind-ui/react",
    "runtime:link": "pnpm --dir packages/runtime add --global . --ignore-scripts",
    "runtime:unlink": "pnpm rm --global @starwind-ui/runtime",
    "core:build": "pnpm --filter=@starwind-ui/core build",
    "core:dev": "pnpm --filter=@starwind-ui/core dev",
    "l": "pnpm runtime:build && pnpm react:build && pnpm cli:build && pnpm runtime:link && pnpm astro:link && pnpm react:link && pnpm cli:link",
    "ul": "pnpm astro:unlink && pnpm react:unlink && pnpm runtime:unlink && pnpm cli:unlink",
    "demo:dev": "pnpm --filter=demo dev",
    "demo:build": "pnpm --filter=demo build",
    "demo:smoke": "pnpm --filter=demo smoke",
    "demo:preview": "pnpm --filter=demo preview",
    "react-demo:dev": "pnpm --filter=react-demo dev",
    "react-demo:build": "pnpm --filter=react-demo build",
    "react-demo:smoke": "pnpm --filter=react-demo smoke",
    "react-demo:preview": "pnpm --filter=react-demo preview",
    "typecheck": "turbo typecheck",
    "check": "pnpm lint:check && pnpm typecheck && pnpm format:check",
    "verify": "pnpm check && pnpm test:all && pnpm test:homes && pnpm runtime:generate:test && pnpm runtime:generate:typecheck && pnpm runtime:docs:metadata:check && pnpm build && pnpm audit --prod --audit-level high",
    "version": "changeset version",
    "local:release": "pnpm build && changeset version && changeset publish",
    "release:beta:prepare": "pnpm runtime:generate:all && pnpm runtime:registry:generate && pnpm runtime:build && pnpm --filter=@starwind-ui/astro typecheck && pnpm react:build && pnpm cli:build",
    "release:beta:gate": "pnpm verify && pnpm demo:smoke && pnpm react-demo:smoke && pnpm runtime:size:check",
    "publish:beta:dry-run": "pnpm release:beta:prepare && pnpm release:beta:gate && node scripts/release-beta-packages.mjs --dry-run",
    "publish:beta": "pnpm release:beta:prepare && pnpm release:beta:gate && node scripts/release-beta-packages.mjs --publish",
    "cli:publish:beta": "cd packages/cli && pnpm publish:beta",
    "cli:publish:next": "cd packages/cli && pnpm publish:next",
    "cli:publish:release": "cd packages/cli && pnpm publish:release",
    "core:publish:beta": "cd packages/core && pnpm publish:beta",
    "core:publish:next": "cd packages/core && pnpm publish:next",
    "core:publish:release": "cd packages/core && pnpm publish:release",
    "runtime:build": "pnpm --filter=@starwind-ui/runtime build",
    "runtime:size": "node scripts/portable-runtime/measure-package-sizes.mjs",
    "runtime:size:check": "node scripts/portable-runtime/measure-package-sizes.mjs --check",
    "runtime:perf": "node scripts/portable-runtime/measure-runtime-performance.mjs",
    "runtime:zag:compare": "node scripts/portable-runtime/generate-zag-feature-comparison.mjs",
    "runtime:zag:compare:check": "node scripts/portable-runtime/generate-zag-feature-comparison.mjs --check",
    "runtime:zag:compare:check:strict": "node scripts/portable-runtime/generate-zag-feature-comparison.mjs --check --require-feature-rows",
    "runtime:docs:metadata": "tsx scripts/portable-runtime/generate-layered-docs-metadata.ts",
    "runtime:docs:metadata:check": "tsx scripts/portable-runtime/generate-layered-docs-metadata.ts --check",
    "runtime:test": "pnpm --filter=@starwind-ui/runtime test:run",
    "runtime:test:coverage": "pnpm --filter=@starwind-ui/runtime exec vitest run --coverage",
    "runtime:generate:all": "pnpm runtime:generate:astro && pnpm runtime:generate:react",
    "runtime:registry:generate": "tsx scripts/portable-runtime/generate-cli-registry.ts && tsx scripts/portable-runtime/generate-primitive-vendoring-artifacts.ts",
    "runtime:primitive-registry:generate": "tsx scripts/portable-runtime/generate-primitive-vendoring-artifacts.ts",
    "runtime:generate:astro": "tsx scripts/portable-runtime/generate-astro-wrappers.ts",
    "runtime:generate:react": "tsx scripts/portable-runtime/generate-react-wrappers.ts",
    "runtime:generate:test": "vitest run scripts/portable-runtime --testTimeout=60000",
    "runtime:generate:typecheck": "tsc -p scripts/portable-runtime/tsconfig.json",
    "runtime:generate:astro:test": "vitest run scripts/portable-runtime/tests/generate-astro-wrappers.test.ts --testTimeout=30000",
    "runtime:generate:react:test": "vitest run scripts/portable-runtime/tests/generate-react-wrappers.test.ts --testTimeout=30000",
    "runtime:generate:vue:check": "tsx scripts/portable-runtime/check-vue-tracer-fixtures.ts",
    "runtime:bundle:test": "pnpm demo:build && node scripts/portable-runtime/assert-astro-demo-bundles.mjs",
    "preinstall": "npx only-allow pnpm",
    "refactor:demo:variants": "node scripts/refactor-starwind-variants.mjs apps/demo/src/components/starwind"
  },
  "dependencies": {
    "turbo": "^2.5.4"
  },
  "devDependencies": {
    "@astrojs/compiler": "^4.0.0",
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "^2.29.7",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "^4.0.16",
    "@vue/compiler-sfc": "3.5.39",
    "eslint": "^9.39.1",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.16",
    "vue": "3.5.39",
    "vue-tsc": "3.3.6"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
